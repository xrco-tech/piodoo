<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="contact_centre_inbox.Inbox">
        <div class="o_action o_cc_inbox d-flex flex-row" style="height: 100%;">

            <!-- ── Left: conversation list ──────────────────────────── -->
            <div class="o_cc_inbox_list d-flex flex-column" t-if="state.showLeftPane">
                <div class="o_cc_inbox_pane_header">
                    <t t-if="campaignId">
                        <i class="fa fa-bullhorn me-1 text-muted" title="Scoped to a campaign"/><t t-esc="campaignName"/>
                    </t>
                    <t t-else="">Conversations</t>
                </div>
                <div class="p-2 border-bottom">
                    <input type="text" class="form-control form-control-sm" placeholder="Search name, phone, email..."
                           t-att-value="state.searchQuery" t-on-input="onSearchInput"/>
                </div>
                <div class="p-2 border-bottom d-flex gap-1">
                    <button class="btn btn-sm" t-att-class="!state.stateFilter ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.filterByState(false)">All</button>
                    <button class="btn btn-sm" t-att-class="state.stateFilter === 'open' ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.filterByState('open')">Open</button>
                    <button class="btn btn-sm" t-att-class="state.stateFilter === 'pending' ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.filterByState('pending')">Pending</button>
                    <button class="btn btn-sm" t-att-class="state.stateFilter === 'resolved' ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.filterByState('resolved')">Resolved</button>
                </div>
                <div class="flex-grow-1 overflow-auto">
                    <div t-if="state.loadingContacts" class="p-3 text-muted">Loading…</div>
                    <t t-foreach="state.contacts" t-as="contact" t-key="contact.id">
                        <div class="p-2 border-bottom o_cc_inbox_contact"
                             t-att-class="{'o_cc_inbox_contact_selected': contact.id === state.selectedContactId}"
                             t-on-click="() => this.selectContact(contact.id)"
                             style="cursor:pointer;">
                            <div class="d-flex justify-content-between align-items-start">
                                <strong><t t-esc="contact.name"/></strong>
                                <span class="badge" t-att-class="{
                                    'text-bg-success': contact.state === 'open',
                                    'text-bg-warning': contact.state === 'pending',
                                    'text-bg-secondary': contact.state === 'resolved',
                                }"><t t-esc="contact.state"/></span>
                            </div>
                            <div class="text-muted small"><t t-esc="contact.phone_number"/></div>
                        </div>
                    </t>
                    <div t-if="!state.loadingContacts and !state.contacts.length" class="p-3 text-muted">
                        No conversations
                    </div>
                </div>
            </div>

            <!-- ── Center: thread + composer ────────────────────────── -->
            <div class="o_cc_inbox_thread flex-grow-1 d-flex flex-column">
                <div class="o_cc_inbox_pane_header d-flex align-items-center gap-2">
                    <button class="btn btn-sm btn-outline-secondary py-0 px-1" t-on-click="toggleLeftPane" title="Show/hide conversations">
                        <i t-att-class="state.showLeftPane ? 'fa fa-angle-double-left' : 'fa fa-angle-double-right'"/>
                    </button>
                    <span>
                        <t t-if="state.selectedContact">
                            <t t-esc="state.selectedContact.name"/>
                            <span class="text-muted fw-normal ms-2 small"><t t-esc="state.selectedContact.phone_number"/></span>
                        </t>
                        <t t-else="">Thread</t>
                    </span>
                    <div class="ms-auto position-relative" t-if="state.selectedContactId">
                        <button class="btn btn-sm btn-success" t-on-click="toggleCallPicker">
                            <i class="fa fa-phone me-1"/>Call WhatsApp
                        </button>
                        <div t-if="state.showCallPicker" class="o_cc_inbox_call_picker">
                            <div class="fw-semibold small text-muted px-2 pt-2 pb-1">Choose a script</div>
                            <div class="o_cc_inbox_call_picker_item" t-on-click="() => this.startVoiceCall(false)">
                                No script (plain call)
                            </div>
                            <t t-foreach="state.voiceChatbots" t-as="chatbot" t-key="chatbot.id">
                                <div class="o_cc_inbox_call_picker_item" t-on-click="() => this.startVoiceCall(chatbot.id)">
                                    <t t-esc="chatbot.name"/>
                                </div>
                            </t>
                            <div t-if="!state.voiceChatbots.length" class="px-2 py-2 text-muted small">
                                No published voice scripts
                            </div>
                        </div>
                    </div>
                </div>
                <t t-if="!state.selectedContactId">
                    <div class="d-flex align-items-center justify-content-center flex-grow-1 text-muted">
                        Select a conversation on the left to see its thread
                    </div>
                </t>
                <t t-else="">
                    <div class="flex-grow-1 overflow-auto p-3">
                        <div t-if="state.loadingMessages" class="text-muted">Loading…</div>
                        <t t-foreach="state.messages" t-as="message" t-key="message.id">
                            <div class="d-flex mb-2"
                                 t-att-class="message.direction === 'outbound' ? 'justify-content-end' : 'justify-content-start'">
                                <div class="o_cc_inbox_bubble p-2"
                                     t-att-class="message.direction === 'outbound' ? 'bg-primary text-white' : 'bg-light'">
                                    <div class="small opacity-75">
                                        <span class="badge text-bg-dark me-1"><t t-esc="message.channel"/></span>
                                        <t t-esc="message.message_timestamp"/>
                                    </div>
                                    <div style="white-space: pre-wrap;"><t t-esc="message.body_text"/></div>
                                    <div class="small opacity-75" t-if="message.direction === 'outbound'">
                                        <t t-esc="message.status"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <div t-if="!state.loadingMessages and !state.messages.length" class="text-muted">
                            No messages yet
                        </div>
                    </div>
                    <div class="border-top p-2 d-flex gap-2 align-items-end">
                        <select class="form-select form-select-sm" style="width: auto;" t-model="state.composerChannel">
                            <option value="whatsapp">WhatsApp</option>
                            <option value="sms">SMS</option>
                        </select>
                        <textarea class="form-control form-control-sm o_cc_inbox_composer" rows="1"
                                  t-ref="composerTextarea"
                                  t-att-value="state.composerText"
                                  t-on-input="onComposerInput"
                                  placeholder="Type a reply..."/>
                        <button class="btn btn-primary btn-sm" t-on-click="sendReply">Send</button>
                    </div>
                </t>
            </div>

            <!-- ── Right: AI copilot + internal notes ───────────────── -->
            <div class="o_cc_inbox_side d-flex flex-column overflow-auto"
                 t-att-class="{'o_cc_inbox_side_wide': state.showInternalNotes or state.showVoiceScript}">
                <div class="o_cc_inbox_pane_header">Copilot &amp; Notes</div>
                <div t-if="state.showVoiceScript and state.selectedContactId" class="o_cc_inbox_tabs d-flex border-bottom">
                    <button class="o_cc_inbox_tab" t-att-class="{'o_cc_inbox_tab_active': state.rightPaneTab === 'script'}"
                            t-on-click="() => this.switchRightPaneTab('script')">Call Script</button>
                    <button class="o_cc_inbox_tab" t-att-class="{'o_cc_inbox_tab_active': state.rightPaneTab === 'copilot'}"
                            t-on-click="() => this.switchRightPaneTab('copilot')">Copilot &amp; Notes</button>
                </div>
                <t t-if="!state.selectedContactId">
                    <div class="p-3 text-muted small">
                        Select a conversation to see its AI summary and internal notes
                    </div>
                </t>
                <t t-else="">
                    <div class="o_cc_inbox_side_section" t-if="state.showVoiceScript and state.rightPaneTab === 'script'">
                        <VoiceScriptPanel sessionId="state.voiceSessionId"
                                          chatbotName="state.voiceChatbotName"
                                          onEnd="() => this.endVoiceScript()"/>
                    </div>
                    <div class="o_cc_inbox_side_section" t-if="(!state.showVoiceScript or state.rightPaneTab === 'copilot') and state.aiAvailable">
                        <h6>AI Copilot</h6>
                        <div class="small text-muted mb-1" t-if="state.ai.ai_analyzed_date">
                            Analyzed <t t-esc="state.ai.ai_analyzed_date"/>
                        </div>
                        <span class="badge mb-1" t-if="state.ai.ai_sentiment" t-att-class="{
                            'text-bg-success': state.ai.ai_sentiment === 'positive',
                            'text-bg-warning': state.ai.ai_sentiment === 'neutral',
                            'text-bg-danger': state.ai.ai_sentiment === 'negative',
                        }"><t t-esc="state.ai.ai_sentiment"/></span>
                        <p class="small" t-if="state.ai.ai_summary"><t t-esc="state.ai.ai_summary"/></p>
                        <div t-if="state.ai.ai_suggested_reply" class="border rounded p-2 small mb-2">
                            <t t-esc="state.ai.ai_suggested_reply"/>
                        </div>
                        <button class="btn btn-sm btn-outline-primary" t-if="state.ai.ai_suggested_reply"
                                t-on-click="insertSuggestedReply">Insert as Reply</button>
                        <div t-if="!state.ai.ai_summary and !state.ai.ai_suggested_reply" class="small text-muted">
                            Not analyzed yet
                        </div>
                    </div>
                    <div class="o_cc_inbox_side_section" t-if="!state.showVoiceScript or state.rightPaneTab === 'copilot'">
                        <button class="btn btn-sm btn-link p-0" t-on-click="toggleInternalNotes">
                            <t t-esc="state.showInternalNotes ? 'Hide Internal Notes' : 'Show Internal Notes'"/>
                        </button>
                        <div t-if="state.showInternalNotes" class="mt-2">
                            <Chatter threadModel="'contact.centre.contact'" threadId="state.selectedContactId"/>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <t t-name="contact_centre_inbox.VoiceScriptPanel">
        <div class="o_cc_voice_script">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <span class="badge text-bg-success me-1">On call</span>
                    <strong t-esc="props.chatbotName"/>
                </div>
                <button class="btn btn-sm btn-outline-danger" t-on-click="endCall">End Call &amp; Script</button>
            </div>

            <div class="o_cc_voice_script_bubbles mb-2">
                <t t-foreach="state.bubbles" t-as="bubble" t-key="bubble_index">
                    <div class="o_cc_voice_script_bubble mb-2">
                        <div t-if="bubble.coaching_notes" class="small text-muted fst-italic mb-1">
                            <t t-esc="bubble.coaching_notes"/>
                        </div>
                        <div style="white-space: pre-wrap;" t-esc="bubble.body"/>
                        <div t-if="bubble.buttons and bubble.buttons.length" class="d-flex flex-wrap gap-1 mt-2">
                            <t t-foreach="bubble.buttons" t-as="btn" t-key="btn">
                                <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.clickOption(btn)">
                                    <t t-esc="btn"/>
                                </button>
                            </t>
                        </div>
                        <div t-if="bubble.list_rows and bubble.list_rows.length" class="mt-2">
                            <t t-foreach="bubble.list_rows" t-as="row" t-key="row">
                                <div class="o_cc_inbox_call_picker_item" t-on-click="() => this.clickOption(row)">
                                    <t t-esc="row"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
                <div t-if="state.loading" class="text-muted small">Loading next step…</div>
            </div>

            <div t-if="state.terminated" class="alert alert-success small py-2">
                Script complete.
            </div>
            <div t-else="" class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm" placeholder="Type the customer's answer..."
                       t-att-value="state.inputText" t-on-input="onInputChange"/>
                <button class="btn btn-primary btn-sm" t-on-click="submitFreeText">Send</button>
            </div>
        </div>
    </t>

</templates>
