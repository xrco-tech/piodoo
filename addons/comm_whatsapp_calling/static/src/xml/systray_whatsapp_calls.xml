<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="comm_whatsapp_calling.WhatsAppCallsSystray" owl="1">
        <div class="o_wa_calls_systray" role="button" t-on-click="onClick">
            <i class="fa fa-phone o_wa_calls_icon"
               title="WhatsApp Calls"
               aria-label="WhatsApp Calls"/>
            <span t-if="state.unansweredCount > 0" class="o_wa_calls_badge">
                <t t-esc="state.unansweredCount"/>
            </span>
        </div>
    </t>
</templates>
