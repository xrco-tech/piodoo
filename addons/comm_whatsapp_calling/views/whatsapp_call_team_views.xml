<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_whatsapp_call_team_list" model="ir.ui.view">
            <field name="name">whatsapp.call.team.list</field>
            <field name="model">whatsapp.call.team</field>
            <field name="arch" type="xml">
                <list string="Call Teams" default_order="sequence, name">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="account_id" optional="show"/>
                    <field name="member_count" string="Members"/>
                    <field name="rule_count" string="Rules"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_whatsapp_call_team_kanban" model="ir.ui.view">
            <field name="name">whatsapp.call.team.kanban</field>
            <field name="model">whatsapp.call.team</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_dashboard">
                    <field name="name"/>
                    <field name="member_count"/>
                    <field name="rule_count"/>
                    <field name="color"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click oe_kanban_color_#{record.color.raw_value}">
                                <div class="o_kanban_card_content">
                                    <div class="o_kanban_card_upper_content">
                                        <div class="o_kanban_record_title">
                                            <field name="name"/>
                                        </div>
                                        <div class="text-muted small">
                                            <field name="description"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_card_lower_content mt-2">
                                        <span class="badge text-bg-info me-1">
                                            <i class="fa fa-users me-1"/><field name="member_count"/> members
                                        </span>
                                        <span class="badge text-bg-secondary">
                                            <i class="fa fa-sitemap me-1"/><field name="rule_count"/> rules
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_whatsapp_call_team_form" model="ir.ui.view">
            <field name="name">whatsapp.call.team.form</field>
            <field name="model">whatsapp.call.team</field>
            <field name="arch" type="xml">
                <form string="Call Team">
                    <sheet>
                        <widget name="web_ribbon" title="Archived"
                                bg_color="bg-danger" invisible="active"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_rules" type="object"
                                    class="oe_stat_button" icon="fa-sitemap">
                                <field name="rule_count" widget="statinfo" string="Rules"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Support Tier 1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="account_id"
                                       options="{'no_create': True}"/>
                                <field name="sequence"/>
                                <field name="color" widget="color_picker"/>
                                <field name="active" invisible="1"/>
                            </group>
                            <group>
                                <field name="description"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Members" name="members">
                                <field name="member_ids"
                                       widget="many2many_avatar_user"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_whatsapp_call_team" model="ir.actions.act_window">
            <field name="name">Call Teams</field>
            <field name="res_model">whatsapp.call.team</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No teams yet
                </p>
                <p>
                    Teams are named queues of agents. Routing rules point
                    at teams, so adding a new hire to a team automatically
                    picks up every rule that team owns.
                </p>
            </field>
        </record>

        <menuitem id="menu_whatsapp_call_team"
                  name="Call Teams"
                  action="action_whatsapp_call_team"
                  parent="comm_whatsapp.menu_whatsapp_root"
                  sequence="21"/>
    </data>
</odoo>
