<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_comm_campaign_simulation_form" model="ir.ui.view">
        <field name="name">comm.campaign.simulation.form</field>
        <field name="model">comm.campaign.simulation</field>
        <field name="arch" type="xml">
            <form string="Campaign Simulator">
                <sheet>
                    <div class="oe_title">
                        <h1>Simulate: <field name="campaign_id" readonly="1"/></h1>
                    </div>

                    <group string="Simulation inputs">
                        <group>
                            <field name="engagement_rate_pct"/>
                        </group>
                        <group>
                            <field name="preview_partner_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_run" type="object"
                                string="Run simulation" class="btn-primary"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>

                    <group string="Summary" invisible="not summary_html">
                        <field name="summary_html" nolabel="1" colspan="2"/>
                    </group>

                    <group invisible="not summary_html">
                        <group string="Audience">
                            <field name="total_audience"/>
                            <field name="reachable_count"/>
                            <field name="opted_out_count"/>
                            <field name="unreachable_count"/>
                        </group>
                        <group string="Cost range">
                            <field name="cost_min_local" string="Min (local)"/>
                            <field name="cost_realistic_local" string="Realistic (local)"/>
                            <field name="cost_max_local" string="Max (local)"/>
                            <field name="display_currency_id"/>
                        </group>
                    </group>

                    <group invisible="not summary_html">
                        <group string="Bot analysis">
                            <field name="guaranteed_step_count"/>
                            <field name="conditional_step_count"/>
                            <field name="llm_step_count"/>
                            <field name="llm_projected_tokens_per_conversation"/>
                        </group>
                        <group string="Budget + ETA">
                            <field name="budget_cap_local"/>
                            <field name="budget_utilization_pct"/>
                            <field name="budget_status" widget="badge"/>
                            <field name="eta_display"/>
                        </group>
                    </group>

                    <notebook invisible="not summary_html">
                        <page string="Channel projection">
                            <field name="channel_projection_html" nolabel="1"/>
                        </page>
                        <page string="Send preview">
                            <field name="send_preview_html" nolabel="1"/>
                        </page>
                        <page string="Interactive walker">
                            <div class="alert alert-info">
                                Step through the bot as if you were the recipient.
                                Outbound sends are captured in the transcript
                                only — nothing hits the channel (force-shadow).
                                LLM steps are skipped by default; toggle
                                <b>Spend real LLM tokens</b> to actually call
                                the Anthropic API.
                            </div>
                            <group>
                                <group>
                                    <field name="walker_channel_id"
                                           domain="[('id', 'in', parent.campaign_id.channel_priority_ids)]"
                                           options="{'no_create': True}"/>
                                    <field name="walker_conversation_id"
                                           readonly="1" invisible="not walker_active"/>
                                    <field name="walker_awaiting" widget="badge"
                                           invisible="not walker_active"/>
                                </group>
                                <group>
                                    <field name="walker_spend_real_llm_tokens"/>
                                    <field name="walker_spent_usd"
                                           invisible="not walker_active"
                                           string="Spent on LLM ($)"/>
                                </group>
                            </group>
                            <div class="alert alert-warning"
                                 invisible="not walker_spend_real_llm_tokens">
                                <b>⚠️ Real tokens will be charged</b> when the
                                walker hits an LLM step. Ensure the Anthropic
                                API key is set in system parameters
                                (<code>comm_chatbot.anthropic_api_key</code>).
                                Typical cost: $0.04–$0.05 per Sonnet 4.6 step.
                            </div>
                            <div>
                                <button name="action_start_walker" type="object"
                                        string="Start walker" class="btn-primary"
                                        invisible="walker_active"/>
                                <button name="action_reset_walker" type="object"
                                        string="Reset"
                                        invisible="not walker_active"/>
                            </div>
                            <div invisible="not walker_active" class="mt-3">
                                <field name="walker_transcript_html" nolabel="1"/>
                                <field name="walker_current_prompt_html" nolabel="1"/>
                                <group invisible="walker_awaiting == 'done'">
                                    <field name="walker_input"
                                           placeholder="Type your reply, then press Send"/>
                                </group>
                                <button name="action_walker_send" type="object"
                                        string="Send" class="btn-primary"
                                        invisible="walker_awaiting == 'done'"/>
                            </div>
                        </page>
                        <page string="A/B variant split">
                            <field name="variant_projection_html" nolabel="1"/>
                        </page>
                        <page string="Assumptions">
                            <field name="assumptions_html" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_comm_campaign_simulation" model="ir.actions.act_window">
        <field name="name">Simulate campaign</field>
        <field name="res_model">comm.campaign.simulation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_campaign_id': active_id}</field>
    </record>

</odoo>
