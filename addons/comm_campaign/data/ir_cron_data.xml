<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_campaign_run" model="ir.cron">
            <field name="name">Comm Campaign: process due campaigns</field>
            <field name="model_id" ref="model_comm_campaign"/>
            <field name="state">code</field>
            <field name="code">model.cron_run()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_purge_walker_conversations" model="ir.cron">
            <field name="name">Comm Campaign: purge orphan walker conversations</field>
            <field name="model_id" ref="comm_chatbot.model_comm_conversation"/>
            <field name="state">code</field>
            <field name="code"><![CDATA[
import datetime
cutoff = datetime.datetime.now() - datetime.timedelta(hours=1)
stale = env['comm.conversation'].search([
    ('outcome', '=', '__preview_walker__'),
    ('create_date', '<', cutoff),
])
stale.sudo().unlink()
]]></field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
