<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Message ID sequence -->
        <record id="seq_contact_centre_message" model="ir.sequence">
            <field name="name">Contact Centre Message</field>
            <field name="code">contact.centre.message</field>
            <field name="prefix">CCM/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
        <!-- Campaign outbound send cron -->
        <record id="ir_cron_campaign_send" model="ir.cron">
            <field name="name">Contact Centre: Process Campaign Sends</field>
            <field name="model_id" ref="model_contact_centre_campaign"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_campaign_sends()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
        </record>
    </data>
</odoo>
