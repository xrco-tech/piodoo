<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Automation List View -->
        <record id="view_contact_centre_automation_list" model="ir.ui.view">
            <field name="name">contact.centre.automation.list</field>
            <field name="model">contact.centre.automation</field>
            <field name="arch" type="xml">
                <list string="Automated Replies">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="channel"/>
                    <field name="trigger_type"/>
                    <field name="trigger_keyword"/>
                    <field name="response_type"/>
                    <field name="campaign_id"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Automation Form View -->
        <record id="view_contact_centre_automation_form" model="ir.ui.view">
            <field name="name">contact.centre.automation.form</field>
            <field name="model">contact.centre.automation</field>
            <field name="arch" type="xml">
                <form string="Automated Reply">
                    <sheet>
                        <group>
                            <group string="Configuration">
                                <field name="name"/>
                                <field name="active"/>
                                <field name="sequence"/>
                                <field name="channel"/>
                                <field name="campaign_id"/>
                            </group>
                            <group string="Trigger">
                                <field name="trigger_type"/>
                                <field name="trigger_keyword" invisible="trigger_type != 'keyword'"/>
                            </group>
                        </group>
                        <group string="Response">
                            <field name="response_type"/>
                            <field name="template_id" invisible="response_type != 'template'"/>
                            <field name="response_text" invisible="response_type != 'text'"
                                   placeholder="Type the automated reply text here..."/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_contact_centre_automation" model="ir.actions.act_window">
            <field name="name">Automated Replies</field>
            <field name="res_model">contact.centre.automation</field>
            <field name="view_mode">list,form</field>
        </record>
        <record id="action_contact_centre_automation_whatsapp" model="ir.actions.act_window">
            <field name="name">WhatsApp Automated Replies</field>
            <field name="res_model">contact.centre.automation</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('channel', 'in', ['whatsapp', 'both'])]</field>
        </record>
        <record id="action_contact_centre_automation_sms" model="ir.actions.act_window">
            <field name="name">SMS Automated Replies</field>
            <field name="res_model">contact.centre.automation</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('channel', 'in', ['sms', 'both'])]</field>
        </record>
        <record id="action_contact_centre_automation_email" model="ir.actions.act_window">
            <field name="name">Email Automated Replies</field>
            <field name="res_model">contact.centre.automation</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('channel', '=', 'email')]</field>
        </record>
    </data>
</odoo>
