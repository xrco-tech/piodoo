<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Campaign List View -->
        <record id="view_contact_centre_campaign_list" model="ir.ui.view">
            <field name="name">contact.centre.campaign.list</field>
            <field name="model">contact.centre.campaign</field>
            <field name="arch" type="xml">
                <list string="Campaigns"
                      decoration-success="state == 'running'"
                      decoration-muted="state in ('done', 'cancelled')">
                    <field name="name"/>
                    <field name="campaign_type"/>
                    <field name="channel"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'running'"
                           decoration-info="state == 'draft'"
                           decoration-muted="state in ('done', 'cancelled')"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="contact_count" string="Contacts"/>
                    <field name="message_count" string="Messages"/>
                    <field name="delivered_count" string="Delivered"/>
                </list>
            </field>
        </record>

        <!-- Campaign Form View -->
        <record id="view_contact_centre_campaign_form" model="ir.ui.view">
            <field name="name">contact.centre.campaign.form</field>
            <field name="model">contact.centre.campaign</field>
            <field name="arch" type="xml">
                <form string="Campaign">
                    <header>
                        <button name="action_start" string="Start" type="object"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_done" string="Mark Done" type="object"
                                invisible="state != 'running'"/>
                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state not in ('draft', 'running')"/>
                        <button name="action_reset_draft" string="Reset to Draft" type="object"
                                invisible="state not in ('done', 'cancelled')"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,running,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object"
                                    name="action_view_contacts" icon="fa-users">
                                <field name="contact_count" widget="statinfo" string="Contacts"/>
                            </button>
                            <button class="oe_stat_button" type="object"
                                    name="action_view_sent" icon="fa-paper-plane"
                                    invisible="sent_count == 0">
                                <field name="sent_count" widget="statinfo" string="Sent"/>
                            </button>
                            <button class="oe_stat_button" type="object"
                                    name="action_view_delivered" icon="fa-check-circle"
                                    invisible="delivered_count == 0">
                                <field name="delivered_count" widget="statinfo" string="Delivered"/>
                            </button>
                            <button class="oe_stat_button" type="object"
                                    name="action_view_failed" icon="fa-exclamation-circle"
                                    invisible="failed_count == 0">
                                <field name="failed_count" widget="statinfo" string="Failed"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="campaign_type"/>
                                <field name="channel"/>
                                <field name="template_id"/>
                                <field name="script_id"/>
                            </group>
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                        </group>
                        <field name="description" placeholder="Campaign description..."/>
                        <notebook>
                            <page string="Automated Replies">
                                <field name="automation_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="trigger_type"/>
                                        <field name="trigger_keyword"/>
                                        <field name="response_type"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Message Log">
                                <field name="message_ids" readonly="1">
                                    <list>
                                        <field name="message_timestamp"/>
                                        <field name="contact_id"/>
                                        <field name="channel"/>
                                        <field name="direction"/>
                                        <field name="body_text"/>
                                        <field name="status" widget="badge"
                                               decoration-success="status in ('delivered','read')"
                                               decoration-warning="status == 'sent'"
                                               decoration-danger="status == 'failed'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Campaign Kanban View -->
        <record id="view_contact_centre_campaign_kanban" model="ir.ui.view">
            <field name="name">contact.centre.campaign.kanban</field>
            <field name="model">contact.centre.campaign</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state">
                    <field name="name"/>
                    <field name="channel"/>
                    <field name="campaign_type"/>
                    <field name="state"/>
                    <field name="contact_count"/>
                    <field name="message_count"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <strong><field name="name"/></strong>
                                <div class="text-muted">
                                    <field name="channel"/> · <field name="campaign_type"/>
                                </div>
                                <div class="mt-2">
                                    <span class="badge bg-info"><field name="contact_count"/> contacts</span>
                                    <span class="badge bg-secondary ms-1"><field name="message_count"/> messages</span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_contact_centre_campaign_overview" model="ir.actions.act_window">
            <field name="name">Campaign Overview</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">kanban,list,form</field>
        </record>
        <record id="action_contact_centre_campaign_inbound" model="ir.actions.act_window">
            <field name="name">Inbound Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'inbound')]</field>
        </record>
        <record id="action_contact_centre_campaign_inbound_whatsapp" model="ir.actions.act_window">
            <field name="name">Inbound WhatsApp Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'inbound'), ('channel', 'in', ['whatsapp', 'both'])]</field>
        </record>
        <record id="action_contact_centre_campaign_inbound_sms" model="ir.actions.act_window">
            <field name="name">Inbound SMS Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'inbound'), ('channel', 'in', ['sms', 'both'])]</field>
        </record>
        <record id="action_contact_centre_campaign_inbound_email" model="ir.actions.act_window">
            <field name="name">Inbound Email Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'inbound'), ('channel', '=', 'email')]</field>
        </record>
        <record id="action_contact_centre_campaign_outbound" model="ir.actions.act_window">
            <field name="name">Outbound Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'outbound')]</field>
        </record>
        <record id="action_contact_centre_campaign_outbound_whatsapp" model="ir.actions.act_window">
            <field name="name">Outbound WhatsApp Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'outbound'), ('channel', 'in', ['whatsapp', 'both'])]</field>
        </record>
        <record id="action_contact_centre_campaign_outbound_sms" model="ir.actions.act_window">
            <field name="name">Outbound SMS Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'outbound'), ('channel', 'in', ['sms', 'both'])]</field>
        </record>
        <record id="action_contact_centre_campaign_outbound_email" model="ir.actions.act_window">
            <field name="name">Outbound Email Campaigns</field>
            <field name="res_model">contact.centre.campaign</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('campaign_type', '=', 'outbound'), ('channel', '=', 'email')]</field>
        </record>
    </data>
</odoo>
