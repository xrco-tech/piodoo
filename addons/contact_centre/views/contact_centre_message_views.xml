<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Message List View -->
        <record id="view_contact_centre_message_list" model="ir.ui.view">
            <field name="name">contact.centre.message.list</field>
            <field name="model">contact.centre.message</field>
            <field name="arch" type="xml">
                <list string="Messages" default_order="message_timestamp desc">
                    <field name="message_timestamp"/>
                    <field name="contact_id"/>
                    <field name="channel" widget="badge"/>
                    <field name="direction" widget="badge"
                           decoration-info="direction == 'inbound'"
                           decoration-success="direction == 'outbound'"/>
                    <field name="message_type"/>
                    <field name="body_text"/>
                    <field name="status" widget="badge"
                           decoration-success="status in ('delivered','read')"
                           decoration-warning="status == 'sent'"
                           decoration-danger="status == 'failed'"
                           decoration-muted="status == 'pending'"/>
                    <field name="campaign_id"/>
                    <field name="assigned_user_id"/>
                </list>
            </field>
        </record>

        <!-- Message Form View -->
        <record id="view_contact_centre_message_form" model="ir.ui.view">
            <field name="name">contact.centre.message.form</field>
            <field name="model">contact.centre.message</field>
            <field name="arch" type="xml">
                <form string="Message">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="contact_id"/>
                                <field name="channel"/>
                                <field name="direction"/>
                                <field name="message_type"/>
                                <field name="status" widget="badge"
                                       decoration-success="status in ('delivered','read')"
                                       decoration-warning="status == 'sent'"
                                       decoration-danger="status == 'failed'"/>
                                <field name="failure_reason" invisible="status != 'failed'"/>
                            </group>
                            <group>
                                <field name="message_timestamp"/>
                                <field name="campaign_id"/>
                                <field name="assigned_user_id"/>
                                <field name="template_id"/>
                                <field name="provider_message_id"/>
                                <field name="whatsapp_message_id" invisible="channel != 'whatsapp'"/>
                                <field name="sms_id" invisible="channel != 'sms'"/>
                            </group>
                        </group>
                        <field name="body_text" readonly="1"/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_contact_centre_message_inbound" model="ir.actions.act_window">
            <field name="name">Inbound Messages</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'inbound')]</field>
        </record>

        <record id="action_contact_centre_message_inbound_whatsapp" model="ir.actions.act_window">
            <field name="name">Inbound WhatsApp</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'inbound'), ('channel', '=', 'whatsapp')]</field>
        </record>

        <record id="action_contact_centre_message_inbound_sms" model="ir.actions.act_window">
            <field name="name">Inbound SMS</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'inbound'), ('channel', '=', 'sms')]</field>
        </record>

        <record id="action_contact_centre_message_inbound_email" model="ir.actions.act_window">
            <field name="name">Inbound Email</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'inbound'), ('channel', '=', 'email')]</field>
        </record>

        <record id="action_contact_centre_message_outbound" model="ir.actions.act_window">
            <field name="name">Outbound Messages</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'outbound')]</field>
        </record>

        <record id="action_contact_centre_message_outbound_whatsapp" model="ir.actions.act_window">
            <field name="name">Outbound WhatsApp</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'outbound'), ('channel', '=', 'whatsapp')]</field>
        </record>

        <record id="action_contact_centre_message_outbound_sms" model="ir.actions.act_window">
            <field name="name">Outbound SMS</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'outbound'), ('channel', '=', 'sms')]</field>
        </record>

        <record id="action_contact_centre_message_outbound_email" model="ir.actions.act_window">
            <field name="name">Outbound Email</field>
            <field name="res_model">contact.centre.message</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('direction', '=', 'outbound'), ('channel', '=', 'email')]</field>
        </record>
    </data>
</odoo>
