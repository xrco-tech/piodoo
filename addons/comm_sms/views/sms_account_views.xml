<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_comm_sms_account_tree" model="ir.ui.view">
            <field name="name">comm.sms.account.tree</field>
            <field name="model">comm.sms.account</field>
            <field name="arch" type="xml">
                <list string="SMS Accounts" default_order="sequence, id">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="provider"/>
                    <field name="sender_id"/>
                    <field name="is_default" widget="boolean_toggle"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_comm_sms_account_form" model="ir.ui.view">
            <field name="name">comm.sms.account.form</field>
            <field name="model">comm.sms.account</field>
            <field name="arch" type="xml">
                <form string="SMS Account">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_sms" type="object"
                                    class="oe_stat_button" icon="fa-comment-o">
                                <field name="sms_count" widget="statinfo" string="SMS"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Marketing Sender"/></h1>
                        </div>
                        <group>
                            <group string="Identity">
                                <field name="provider"/>
                                <field name="sender_id" placeholder="+27693808740 or PIODOO"/>
                            </group>
                            <group string="Routing">
                                <field name="is_default"/>
                                <field name="active" invisible="1"/>
                                <field name="sequence"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Credentials" name="credentials" invisible="provider != 'infobip'">
                                <group>
                                    <field name="base_url" placeholder="https://your-instance.api.infobip.com"/>
                                    <field name="api_key" password="True" placeholder="API key for outbound"/>
                                    <field name="retention_period"/>
                                </group>
                                <div class="alert alert-info" role="alert">
                                    Inbound MO callback: <code>/sms/infobip/inbound</code> —
                                    the controller routes by the inbound <em>to</em> field
                                    matched against this <strong>Sender ID</strong>.
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_comm_sms_account" model="ir.actions.act_window">
            <field name="name">SMS Accounts</field>
            <field name="res_model">comm.sms.account</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_comm_sms_accounts"
                  name="SMS Accounts"
                  parent="base.menu_administration"
                  action="action_comm_sms_account"
                  groups="base.group_system"
                  sequence="60"/>

    </data>
</odoo>
