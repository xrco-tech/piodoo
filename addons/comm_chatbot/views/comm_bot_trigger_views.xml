<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_comm_bot_trigger_list" model="ir.ui.view">
        <field name="name">comm.bot.trigger.list</field>
        <field name="model">comm.bot.trigger</field>
        <field name="arch" type="xml">
            <list>
                <field name="bot_id"/>
                <field name="channel_id"/>
                <field name="kind"/>
                <field name="value"/>
                <field name="match_mode"/>
                <field name="priority"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_comm_bot_trigger" model="ir.actions.act_window">
        <field name="name">Triggers</field>
        <field name="res_model">comm.bot.trigger</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
