<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_comm_conversation_list" model="ir.ui.view">
        <field name="name">comm.conversation.list</field>
        <field name="model">comm.conversation</field>
        <field name="arch" type="xml">
            <list>
                <field name="opened_at"/>
                <field name="partner_id"/>
                <field name="bot_id"/>
                <field name="primary_channel_id"/>
                <field name="current_step_id"/>
                <field name="lifecycle_state" widget="badge"/>
                <field name="interaction_count"/>
                <field name="last_activity_at"/>
                <field name="assigned_agent_id"/>
            </list>
        </field>
    </record>

    <record id="view_comm_conversation_form" model="ir.ui.view">
        <field name="name">comm.conversation.form</field>
        <field name="model">comm.conversation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="bot_id"/>
                            <field name="current_step_id"/>
                            <field name="primary_channel_id"/>
                        </group>
                        <group>
                            <field name="lifecycle_state" widget="badge"/>
                            <field name="opened_at"/>
                            <field name="last_activity_at"/>
                            <field name="timeout_at"/>
                            <field name="closed_at"/>
                            <field name="outcome"/>
                            <field name="assigned_agent_id"/>
                            <field name="campaign_id"/>
                        </group>
                    </group>
                    <field name="state" widget="ace" options="{'mode': 'json'}"/>
                    <notebook>
                        <page string="Legs">
                            <field name="leg_ids">
                                <list>
                                    <field name="channel_id"/>
                                    <field name="external_session_id"/>
                                    <field name="opened_at"/>
                                    <field name="closed_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="Interactions">
                            <field name="interaction_ids">
                                <list>
                                    <field name="at"/>
                                    <field name="channel_id"/>
                                    <field name="direction"/>
                                    <field name="step_id"/>
                                    <field name="rendered_body"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_comm_conversation_search" model="ir.ui.view">
        <field name="name">comm.conversation.search</field>
        <field name="model">comm.conversation</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="bot_id"/>
                <field name="primary_channel_id"/>
                <field name="campaign_id"/>
                <filter string="Open" name="open"
                        domain="[('lifecycle_state', 'in', ['open', 'waiting'])]"/>
                <filter string="Handed off" name="handoff"
                        domain="[('lifecycle_state', '=', 'handoff')]"/>
                <filter string="Closed" name="closed"
                        domain="[('lifecycle_state', 'in', ['closed', 'timeout'])]"/>
                <separator/>
                <filter string="Hide previews" name="hide_previews"
                        domain="['|', ('outcome', '=', False), ('outcome', 'not like', '\_\_%')]"/>
                <group expand="0" string="Group by">
                    <filter string="Bot" name="group_bot"
                            context="{'group_by': 'bot_id'}"/>
                    <filter string="Channel" name="group_channel"
                            context="{'group_by': 'primary_channel_id'}"/>
                    <filter string="Lifecycle" name="group_lifecycle"
                            context="{'group_by': 'lifecycle_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_comm_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">comm.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1, 'search_default_hide_previews': 1}</field>
    </record>

</odoo>
