<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Anthropic Claude pricing — 2026.
            Rates in USD per 1,000 tokens (kilotokens).

            Cache pricing:
            - Cache write: 25% surcharge over input rate
            - Cache read:  90% discount off input rate

            Verify against console.anthropic.com/pricing before invoicing.
        -->

        <record id="rate_card_anthropic_2026" model="comm.billing.rate.card">
            <field name="name">Anthropic Claude — 2026</field>
            <field name="channel">other</field>
            <field name="provider">Anthropic</field>
            <field name="effective_from">2026-01-01</field>
            <field name="billing_model">generic</field>
            <field name="notes">Per-model input/output token rates plus cache read/write. Carrier field holds the model name.</field>
        </record>

        <!-- =============== Claude Opus 4.7 =============== -->

        <record id="rate_anthropic_opus_4_7_input" model="comm.billing.rate">
            <field name="card_id" ref="rate_card_anthropic_2026"/>
            <field name="carrier">claude-opus-4-7</field>
            <field name="category">llm_input</field>
            <field name="unit">kilotoken</field>
            <field name="price_usd">0.015</field>
        </record>

