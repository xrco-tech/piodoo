<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_close_stale_conversations" model="ir.cron">
            <field name="name">Comm Chatbot: close stale conversations</field>
            <field name="model_id" ref="model_comm_conversation"/>
            <field name="state">code</field>
            <field name="code">model.cron_close_stale()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
