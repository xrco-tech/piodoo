<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_chatbot_administrator" model="res.groups">
            <field name="name">Chatbot Administrator</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="comment">Full access to bot design, channels, and runtime.</field>
        </record>
        <record id="group_chatbot_designer" model="res.groups">
            <field name="name">Chatbot Designer</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="comment">Can design bots but not modify channels or system config.</field>
            <field name="implied_ids" eval="[(4, ref('group_chatbot_agent'))]"/>
        </record>
        <record id="group_chatbot_agent" model="res.groups">
            <field name="name">Chatbot Agent</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="comment">Handles handoffs; can view conversations and interactions.</field>
        </record>
    </data>
</odoo>
