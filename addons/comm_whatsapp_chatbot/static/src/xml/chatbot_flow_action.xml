<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="comm_whatsapp_chatbot.ChatbotFlowAction">
        <div class="o_chatbot_flow_action">

            <!-- Toolbar -->
            <div class="o_chatbot_flow_toolbar">
                <div class="o_chatbot_flow_toolbar_left">
                    <button class="btn btn-sm btn-light o_flow_back_btn"
                            t-on-click="() => this._goBack()"
                            title="Back to chatbot details">
                        <i class="fa fa-chevron-left"/>
                    </button>
                    <button class="btn btn-sm btn-primary o_flow_add_step_btn"
                            t-on-click="() => this._openCreateDialog(false)"
                            title="Add a new top-level step">
                        Add Step
                    </button>
                    <span class="o_chatbot_flow_title" t-esc="state.chatbotName"/>
                </div>
                <div class="o_chatbot_flow_toolbar_right">
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom - 0.1)">−</button>
                    <span class="o_flow_zoom_label" t-esc="zoomLabel"/>
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom + 0.1)">+</button>
                    <button class="btn btn-sm btn-light ms-2"
                            t-on-click="() => this._resetLayout()"
                            title="Reset to automatic tree layout">
                        <i class="fa fa-sitemap"/>
                    </button>
                    <button class="btn btn-sm btn-light"
                            t-on-click="() => this._togglePanel()"
                            t-att-title="state.panelVisible ? 'Hide properties panel' : 'Show properties panel'"
                            t-att-class="state.panelVisible ? '' : 'active'">
                        <i t-att-class="state.panelVisible ? 'fa fa-angle-double-right' : 'fa fa-angle-double-left'"/>
                    </button>
                </div>
            </div>

            <!-- Body: canvas + properties panel side-by-side -->
            <div class="o_chatbot_flow_body">

                <!-- Canvas area -->
                <div class="o_chatbot_flow_canvas_wrap">
                    <div t-if="state.loading" class="o_chatbot_flow_loading">
                        <div class="o_loading_spinner"/>
                    </div>
                    <div t-else="" class="o_chatbot_flow_canvas" t-ref="canvas"/>
                </div>

                <!-- Properties panel -->
                <div t-att-class="'o_chatbot_flow_props' + (state.panelVisible ? '' : ' o_chatbot_flow_props_collapsed')"
                     t-if="!state.loading">
                    <!-- Tab switcher: Properties | Simulator -->
                    <div class="o_flow_panel_tabs">
                        <button t-att-class="'o_flow_panel_tab' + (state.panelMode === 'props' ? ' active' : '')"
                                t-on-click="() => this._setPanelMode('props')">
                            <i class="fa fa-info-circle me-1"/>Properties
                        </button>
                        <button t-att-class="'o_flow_panel_tab' + (state.panelMode === 'sim' ? ' active' : '')"
                                t-on-click="() => this._setPanelMode('sim')">
                            <i class="fa fa-play-circle me-1"/>Simulator
                        </button>
                    </div>

                    <!-- Simulator tab content -->
                    <t t-if="state.panelMode === 'sim'">
                        <div t-attf-class="o_flow_sim o_flow_sim_#{state.sim.channel}">

                            <!-- Persona form (shown before the session starts) -->
                            <t t-if="!state.sim.started">
                                <div class="o_flow_sim_persona_form">
                                    <div class="o_flow_sim_persona_title">
                                        Run as a contact
                                    </div>
                                    <div class="o_flow_sim_persona_help">
                                        Set the name and mobile of the test user; the bot will
                                        run as if this contact dialled / messaged it.
                                    </div>
                                    <label class="o_flow_sim_persona_label">Name</label>
                                    <input type="text" class="o_flow_sim_persona_input"
                                           t-model="state.sim.personaName"
                                           placeholder="e.g. Alice Test"/>
                                    <label class="o_flow_sim_persona_label">Mobile</label>
                                    <input type="tel" class="o_flow_sim_persona_input"
                                           t-model="state.sim.personaMobile"
                                           placeholder="+27600000001"/>

                                    <!-- Variables: grouped per chatbot (root + linked via jump_to_flow) -->
                                    <t t-foreach="state.sim.setupBots" t-as="bot" t-key="bot.chatbot_id">
                                        <t t-if="bot.variables and bot.variables.length">
                                            <div class="o_flow_sim_vars_group">
                                                <div class="o_flow_sim_vars_group_title">
                                                    <i class="fa fa-tag me-1"/>
                                                    <t t-esc="bot.chatbot_name"/>
                                                    <span t-if="!bot.is_root" class="text-muted small ms-1">(linked)</span>
                                                </div>
                                                <t t-foreach="bot.variables" t-as="v" t-key="v.id">
                                                    <label class="o_flow_sim_persona_label" t-attf-for="sim_var_#{v.id}">
                                                        <t t-esc="v.name"/>
                                                        <span class="text-muted small ms-1">(<t t-esc="v.data_type"/>)</span>
                                                    </label>
                                                    <input class="o_flow_sim_persona_input"
                                                           t-attf-id="sim_var_#{v.id}"
                                                           t-att-type="v.data_type === 'integer' || v.data_type === 'float' ? 'number' : (v.data_type === 'date' ? 'date' : 'text')"
                                                           t-model="v.value"
                                                           t-attf-placeholder="e.g. value for #{v.name}"/>
                                                </t>
                                            </div>
                                        </t>
                                    </t>

                                    <button class="btn btn-primary w-100 mt-2"
                                            t-on-click="() => this._simStart()">
                                        <i class="fa fa-play me-1"/>Start session
                                    </button>
                                </div>
                            </t>

                            <div t-if="state.sim.started" class="o_flow_sim_phone">
                                <div class="o_flow_sim_phone_status">
                                    <span class="o_flow_sim_channel_pill">
                                        <t t-esc="state.sim.channel.toUpperCase()"/>
                                    </span>
                                    <div class="o_flow_sim_persona_chip" t-on-click="() => this._simToggleEditor()"
                                         title="Click to edit persona + variables">
                                        <i class="fa fa-user me-1"/>
                                        <span class="o_flow_sim_persona_chip_name"
                                              t-esc="state.sim.personaName or state.sim.personaMobile"/>
                                        <i class="fa fa-pencil ms-1 o_flow_sim_persona_chip_pencil"/>
                                    </div>
                                    <button class="btn btn-sm btn-link o_flow_sim_restart"
                                            t-on-click="() => this._simStart()"
                                            title="Restart simulator session">
                                        <i class="fa fa-refresh"/>
                                    </button>
                                </div>

                                <!-- In-session editor: persona + variables editable without
                                     restarting the flow. Toggled by clicking the persona chip. -->
                                <t t-if="state.sim.editorOpen">
                                    <div class="o_flow_sim_editor">
                                        <div class="o_flow_sim_editor_title">
                                            <i class="fa fa-pencil-square-o me-1"/>Edit persona &amp; variables
                                            <button class="btn btn-sm btn-link float-end p-0"
                                                    t-on-click="() => this._simToggleEditor()"
                                                    title="Close">
                                                <i class="fa fa-times"/>
                                            </button>
                                        </div>
                                        <label class="o_flow_sim_persona_label">Name</label>
                                        <input type="text" class="o_flow_sim_persona_input"
                                               t-model="state.sim.personaName"/>
                                        <label class="o_flow_sim_persona_label">Mobile</label>
                                        <input type="tel" class="o_flow_sim_persona_input"
                                               t-model="state.sim.personaMobile"/>
                                        <t t-foreach="state.sim.setupBots" t-as="bot" t-key="bot.chatbot_id">
                                            <t t-if="bot.variables and bot.variables.length">
                                                <div class="o_flow_sim_vars_group">
                                                    <div class="o_flow_sim_vars_group_title">
                                                        <i class="fa fa-tag me-1"/>
                                                        <t t-esc="bot.chatbot_name"/>
                                                        <span t-if="!bot.is_root" class="text-muted small ms-1">(linked)</span>
                                                    </div>
                                                    <t t-foreach="bot.variables" t-as="v" t-key="v.id">
                                                        <label class="o_flow_sim_persona_label">
                                                            <t t-esc="v.name"/>
                                                            <span class="text-muted small ms-1">(<t t-esc="v.data_type"/>)</span>
                                                        </label>
                                                        <input class="o_flow_sim_persona_input"
                                                               t-att-type="v.data_type === 'integer' || v.data_type === 'float' ? 'number' : (v.data_type === 'date' ? 'date' : 'text')"
                                                               t-model="v.value"/>
                                                    </t>
                                                </div>
                                            </t>
                                        </t>
                                        <button class="btn btn-primary w-100 mt-2"
                                                t-att-disabled="state.sim.editorSaving"
                                                t-on-click="() => this._simApplyEditor()">
                                            <i class="fa fa-check me-1"/>
                                            <t t-if="state.sim.editorSaving">Applying...</t>
                                            <t t-else="">Apply changes</t>
                                        </button>
                                    </div>
                                </t>

                                <div class="o_flow_sim_chat">
                                    <t t-foreach="state.sim.bubbles" t-as="b" t-key="b_index">

                                        <!-- User-sent bubble: plain escaped text -->
                                        <t t-if="b.dir === 'out'">
                                            <div class="o_flow_sim_bubble o_flow_sim_bubble_out o_flow_sim_bubble_t_user"
                                                 t-out="simEscape(b.text)"/>
                                        </t>

                                        <!-- Numbered menu (always plain monospace) -->
                                        <t t-elif="b.step_type === 'menu'">
                                            <div class="o_flow_sim_bubble o_flow_sim_bubble_in o_flow_sim_bubble_t_menu"
                                                 t-out="simEscape(b.text)"/>
                                        </t>

                                        <!-- Notes / errors -->
                                        <t t-elif="b.step_type === 'error' or b.step_type === 'sim_note'">
                                            <div t-attf-class="o_flow_sim_bubble o_flow_sim_bubble_in o_flow_sim_bubble_t_#{b.step_type}"
                                                 t-out="simEscape(b.text)"/>
                                        </t>

                                        <!-- Bot bubble: rich rendering per channel -->
                                        <t t-else="">
                                            <div t-attf-class="o_flow_sim_bubble o_flow_sim_bubble_in o_flow_sim_bubble_t_#{b.step_type}">

                                                <!-- WhatsApp: header (text/media/document) -->
                                                <t t-if="b.channel === 'whatsapp' and b.header_type === 'text' and b.header_text">
                                                    <div class="o_flow_bubble_header_text" t-out="simEscape(b.header_text)"/>
                                                </t>
                                                <t t-if="b.channel === 'whatsapp' and b.header_type === 'image'">
                                                    <div class="o_flow_bubble_header_media">
                                                        <i class="fa fa-image"/><span>Image</span>
                                                    </div>
                                                </t>
                                                <t t-if="b.channel === 'whatsapp' and b.header_type === 'video'">
                                                    <div class="o_flow_bubble_header_media">
                                                        <i class="fa fa-play-circle"/><span>Video</span>
                                                    </div>
                                                </t>
                                                <t t-if="b.channel === 'whatsapp' and b.header_type === 'document'">
                                                    <div class="o_flow_bubble_header_doc">
                                                        <i class="fa fa-file-text-o"/>
                                                        <span><t t-esc="b.header_text or 'Document'"/></span>
                                                    </div>
                                                </t>

                                                <!-- Body with channel-appropriate formatting -->
                                                <t t-if="b.body or b.text">
                                                    <div class="o_flow_bubble_body"
                                                         t-out="simFormatBody(b.body or b.text, b.channel || state.sim.channel)"/>
                                                </t>

                                                <!-- Footer (WhatsApp) -->
                                                <t t-if="b.channel === 'whatsapp' and b.footer">
                                                    <div class="o_flow_bubble_footer" t-out="simEscape(b.footer)"/>
                                                </t>

                                                <!-- Media-question placeholder (image/video/audio/document) -->
                                                <t t-if="b.step_type === 'question_image'">
                                                    <div class="o_flow_sim_media_prompt">
                                                        <i class="fa fa-camera"/>
                                                        <span>Send a photo to continue</span>
                                                    </div>
                                                </t>
                                                <t t-elif="b.step_type === 'question_video'">
                                                    <div class="o_flow_sim_media_prompt">
                                                        <i class="fa fa-video-camera"/>
                                                        <span>Send a video to continue</span>
                                                    </div>
                                                </t>
                                                <t t-elif="b.step_type === 'question_audio'">
                                                    <div class="o_flow_sim_media_prompt">
                                                        <i class="fa fa-microphone"/>
                                                        <span>Send a voice note to continue</span>
                                                    </div>
                                                </t>
                                                <t t-elif="b.step_type === 'question_document'">
                                                    <div class="o_flow_sim_media_prompt">
                                                        <i class="fa fa-file-text-o"/>
                                                        <span>Send a document to continue</span>
                                                    </div>
                                                </t>

                                                <!-- Interactive flow CTA (WhatsApp) — clickable -->
                                                <t t-if="b.channel === 'whatsapp' and b.wa_message_type === 'interactive_flow'">
                                                    <div class="o_flow_bubble_flow_sep"/>
                                                    <button class="o_flow_bubble_flow_cta o_flow_sim_clickable"
                                                            t-att-disabled="state.sim.sending or state.sim.terminate"
                                                            t-on-click="() => this._simSendQuickReply(b.flow_cta or 'Open')">
                                                        <span><t t-esc="b.flow_cta or 'Open'"/></span>
                                                        <i class="fa fa-chevron-right"/>
                                                    </button>
                                                </t>

                                                <!-- Reply buttons (WhatsApp) — clickable -->
                                                <t t-if="b.channel === 'whatsapp' and b.buttons and b.buttons.length">
                                                    <div class="o_flow_ia_sep"/>
                                                    <t t-foreach="b.buttons" t-as="btn" t-key="btn_index">
                                                        <button class="o_flow_ia_btn o_flow_sim_clickable"
                                                                t-att-disabled="state.sim.sending or state.sim.terminate"
                                                                t-on-click="() => this._simSendQuickReply(btn)"
                                                                t-esc="btn"/>
                                                    </t>
                                                </t>

                                                <!-- Interactive list (WhatsApp) — clickable rows -->
                                                <t t-if="b.channel === 'whatsapp' and b.list_rows and b.list_rows.length">
                                                    <div class="o_flow_ia_sep"/>
                                                    <div class="o_flow_ia_list_btn">
                                                        <i class="fa fa-list me-1"/>
                                                        <t t-esc="b.list_button_text or 'See all options'"/>
                                                    </div>
                                                    <t t-foreach="b.list_rows" t-as="row" t-key="row_index">
                                                        <button class="o_flow_ia_list_row o_flow_sim_clickable"
                                                                t-att-disabled="state.sim.sending or state.sim.terminate"
                                                                t-on-click="() => this._simSendQuickReply(row)"
                                                                t-esc="row"/>
                                                    </t>
                                                </t>

                                            </div>
                                        </t>
                                    </t>

                                    <t t-if="state.sim.sending">
                                        <div class="o_flow_sim_bubble o_flow_sim_bubble_in o_flow_sim_typing">
                                            <span class="dot"/><span class="dot"/><span class="dot"/>
                                        </div>
                                    </t>
                                </div>
                                <t t-if="state.sim.terminate">
                                    <div class="o_flow_sim_terminated">
                                        Session ended. Click <i class="fa fa-refresh"/> to restart.
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="o_flow_sim_input_row">
                                        <input type="text" class="o_flow_sim_input"
                                               t-model="state.sim.userInput"
                                               t-on-keydown="(ev) => this._simOnInputKey(ev)"
                                               t-att-placeholder="state.sim.channel === 'ussd' ? 'Type your input...' : 'Type a message...'"
                                               t-att-disabled="state.sim.sending"/>
                                        <button class="btn btn-sm btn-primary o_flow_sim_send"
                                                t-on-click="() => this._simSendInput()"
                                                t-att-disabled="state.sim.sending or !state.sim.userInput.trim()">
                                            <i class="fa fa-paper-plane"/>
                                        </button>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- Properties tab content -->
                    <t t-if="state.panelMode === 'props' and state.selectedNode">

                        <!-- Dead-end warning -->
                        <t t-if="state.selectedNode.isDeadEnd">
                            <div class="o_flow_props_warning">
                                <i class="fa fa-exclamation-triangle me-1"/>
                                <strong>Dead-end step</strong>
                                <div class="mt-1">This step has no child steps and is not a terminal node. Users will have no path forward. Add a child step, or change the type to <em>End Flow</em> or <em>Transfer to Agent</em>.</div>
                            </div>
                        </t>

                        <!-- Type badge -->
                        <div class="o_flow_props_type_row">
                            <span class="o_flow_card_badge o_flow_props_badge"
                                  t-att-style="'background:' + typeCfg(state.selectedNode.type).color">
                                <t t-esc="typeCfg(state.selectedNode.type).icon"/>
                                <t t-esc="typeCfg(state.selectedNode.type).label"/>
                            </span>
                        </div>

                        <!-- Name -->
                        <div class="o_flow_props_label">Name</div>
                        <div class="o_flow_props_value fw-semibold mb-2">
                            <t t-esc="state.selectedNode.name"/>
                        </div>

                        <!-- Sequence + WA delivery type (side by side) -->
                        <div class="o_flow_props_meta_row">
                            <div>
                                <div class="o_flow_props_label">Sequence</div>
                                <div class="o_flow_props_value">#<t t-esc="state.selectedNode.sequence"/></div>
                            </div>
                            <t t-if="state.selectedNode.waType and state.selectedNode.waType != 'non_interactive'">
                                <div>
                                    <div class="o_flow_props_label">Delivery</div>
                                    <span class="o_flow_props_wa_badge"
                                          t-att-style="'background:' + waTypeBadgeColor(state.selectedNode.waType)">
                                        <t t-esc="waTypeLabel(state.selectedNode.waType)"/>
                                    </span>
                                </div>
                            </t>
                            <t t-else="">
                                <div>
                                    <div class="o_flow_props_label">Delivery</div>
                                    <div class="o_flow_props_value">Plain</div>
                                </div>
                            </t>
                        </div>

                        <!-- Reach / funnel stats -->
                        <t t-if="state.maxCount > 0">
                            <div class="o_flow_props_label mt-2">Reached</div>
                            <div class="o_flow_props_reach_row">
                                <span class="o_flow_props_reach_num">👤 <t t-esc="state.selectedNode.msgCount or 0"/></span>
                                <div class="o_flow_props_reach_bar_wrap">
                                    <div class="o_flow_props_reach_bar_fill"
                                         t-att-style="'width:' + reachPct(state.selectedNode.msgCount) + '%;background:' + reachColor(state.selectedNode.msgCount)"/>
                                </div>
                                <span class="o_flow_props_reach_pct"
                                      t-att-style="'color:' + reachColor(state.selectedNode.msgCount)">
                                    <t t-esc="reachPct(state.selectedNode.msgCount)"/>%
                                </span>
                            </div>
                            <t t-set="_drop" t-value="dropOffPct(state.selectedNode.msgCount, state.selectedNode.parentId)"/>
                            <t t-if="_drop !== null">
                                <div class="o_flow_props_drop_lbl">↓ <t t-esc="_drop"/>% from parent</div>
                            </t>
                        </t>

                        <!-- Message preview -->
                        <t t-if="state.selectedNode.preview_html">
                            <div class="o_flow_props_label mt-2">Message</div>
                            <div class="o_flow_bubble o_flow_props_bubble"
                                 t-out="state.selectedNode.preview_html"/>
                        </t>

                        <!-- Header -->
                        <t t-if="state.selectedNode.headerType">
                            <div class="o_flow_props_label mt-2">Header</div>
                            <div class="o_flow_props_value o_flow_props_icon_row">
                                <i t-att-class="'fa ' + headerTypeIcon(state.selectedNode.headerType)"/>
                                <t t-esc="headerTypeLabel(state.selectedNode.headerType)"/>
                                <t t-if="state.selectedNode.headerType == 'text' and state.selectedNode.headerText">
                                    — <em><t t-esc="state.selectedNode.headerText"/></em>
                                </t>
                            </div>
                        </t>

                        <!-- Footer -->
                        <t t-if="state.selectedNode.footer">
                            <div class="o_flow_props_label mt-2">Footer</div>
                            <div class="o_flow_props_value o_flow_props_footer_val">
                                <t t-esc="state.selectedNode.footer"/>
                            </div>
                        </t>

                        <!-- Answer type (question steps) -->
                        <t t-if="isQuestionType(state.selectedNode.type) and state.selectedNode.answerDataType">
                            <div class="o_flow_props_label mt-2">Expected Answer</div>
                            <div class="o_flow_props_value">
                                <t t-esc="answerTypeLabel(state.selectedNode.answerDataType)"/>
                            </div>
                        </t>

                        <!-- Reply buttons -->
                        <t t-if="state.selectedNode.waType == 'interactive_button' and state.selectedNode.buttons.length">
                            <div class="o_flow_props_label mt-2">Reply Buttons</div>
                            <div class="o_flow_props_ia_list">
                                <t t-foreach="state.selectedNode.buttons" t-as="btn" t-key="btn_index">
                                    <div class="o_flow_props_ia_item"><t t-esc="btn"/></div>
                                </t>
                            </div>
                        </t>

                        <!-- List rows -->
                        <t t-if="state.selectedNode.waType == 'interactive_list'">
                            <div class="o_flow_props_label mt-2">List</div>
                            <div class="o_flow_props_value o_flow_props_icon_row">
                                <i class="fa fa-list-ul"/>
                                <t t-esc="state.selectedNode.listBtnText"/>
                            </div>
                            <t t-if="state.selectedNode.listRows.length">
                                <div class="o_flow_props_ia_list">
                                    <t t-foreach="state.selectedNode.listRows" t-as="row" t-key="row_index">
                                        <div class="o_flow_props_ia_item"><t t-esc="row"/></div>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- Interactive flow -->
                        <t t-if="state.selectedNode.waType == 'interactive_flow'">
                            <div class="o_flow_props_label mt-2">Flow</div>
                            <t t-if="state.selectedNode.flowName">
                                <div class="o_flow_props_value o_flow_props_icon_row">
                                    <i class="fa fa-bolt"/>
                                    <t t-esc="state.selectedNode.flowName"/>
                                </div>
                            </t>
                            <t t-if="state.selectedNode.flowCta">
                                <div class="o_flow_props_label mt-1">CTA</div>
                                <div class="o_flow_props_value o_flow_props_flow_cta">
                                    <t t-esc="state.selectedNode.flowCta"/>
                                </div>
                            </t>
                        </t>

                        <!-- Retry / fallback (question steps) -->
                        <t t-if="isQuestionType(state.selectedNode.type)">
                            <div class="o_flow_props_label mt-2">Max Retries</div>
                            <div class="o_flow_props_value"><t t-esc="state.selectedNode.maxRetries"/></div>
                            <t t-if="state.selectedNode.fallbackStepName">
                                <div class="o_flow_props_label mt-1">Fallback Step</div>
                                <div class="o_flow_props_value o_flow_props_icon_row">
                                    <i class="fa fa-share-square-o"/>
                                    <t t-esc="state.selectedNode.fallbackStepName"/>
                                </div>
                            </t>
                        </t>

                        <!-- Jump to Flow/Bot -->
                        <t t-if="state.selectedNode.type == 'jump_to_flow'">
                            <div class="o_flow_props_label mt-2">Target Chatbot</div>
                            <div class="o_flow_props_value fw-semibold">
                                <t t-if="state.selectedNode.targetChatbotId">
                                    <a href="#"
                                       class="o_flow_props_target_link"
                                       title="Open target chatbot"
                                       t-on-click.prevent.stop="() => this._openTargetChatbot(state.selectedNode.targetChatbotId, state.selectedNode.targetChatbotName)">
                                        <t t-esc="state.selectedNode.targetChatbotName"/>
                                        <i class="fa fa-external-link ms-1"/>
                                    </a>
                                </t>
                                <t t-else="">
                                    <span class="text-danger">— Not configured —</span>
                                </t>
                            </div>
                            <div class="o_flow_props_label mt-1">Entry Step</div>
                            <div class="o_flow_props_value">
                                <t t-if="state.selectedNode.targetStepName">
                                    <t t-esc="state.selectedNode.targetStepName"/>
                                </t>
                                <t t-else="">
                                    <em class="text-muted">Root step of target chatbot</em>
                                </t>
                            </div>
                            <div class="o_flow_props_label mt-1">Mode</div>
                            <div class="o_flow_props_value">
                                <t t-if="state.selectedNode.jumpMode == 'subroutine'">
                                    <span class="o_flow_jump_mode o_flow_jump_mode_sub">↺ Subroutine</span>
                                    <div class="text-muted small mt-1">Resumes the caller when the target ends.</div>
                                </t>
                                <t t-else="">
                                    <span class="o_flow_jump_mode o_flow_jump_mode_one">→ One-way</span>
                                    <div class="text-muted small mt-1">The new flow takes over — no return.</div>
                                </t>
                            </div>
                            <t t-if="state.selectedNode.varMappingCount">
                                <div class="o_flow_props_label mt-1">Variable Mapping</div>
                                <div class="o_flow_props_value">
                                    <t t-esc="state.selectedNode.varMappingCount"/> rule<t t-if="state.selectedNode.varMappingCount != 1">s</t>
                                </div>
                            </t>
                        </t>

                        <!-- Variable (set_variable steps) -->
                        <t t-if="state.selectedNode.type == 'set_variable' and state.selectedNode.variableName">
                            <div class="o_flow_props_label mt-2">Variable</div>
                            <div class="o_flow_props_value fw-semibold">
                                <t t-esc="state.selectedNode.variableName"/>
                            </div>
                            <t t-if="state.selectedNode.variableDataSource">
                                <div class="o_flow_props_label mt-1">Source</div>
                                <div class="o_flow_props_value">
                                    <t t-esc="varSourceLabel(state.selectedNode.variableDataSource, state.selectedNode)"/>
                                </div>
                            </t>
                        </t>

                        <!-- Trigger answers -->
                        <t t-if="state.selectedNode.answers and state.selectedNode.answers.length">
                            <div class="o_flow_props_label mt-2">Trigger Conditions</div>
                            <div class="o_flow_chips">
                                <t t-foreach="state.selectedNode.answers" t-as="ans" t-key="ans_index">
                                    <span class="o_flow_chip"><t t-esc="ans"/></span>
                                </t>
                            </div>
                        </t>

                        <!-- Child steps count -->
                        <t t-if="state.selectedNode.children and state.selectedNode.children.length">
                            <div class="o_flow_props_label mt-2">Child Steps</div>
                            <div class="o_flow_props_value">
                                <t t-esc="state.selectedNode.children.length"/>
                            </div>
                        </t>

                        <!-- Actions -->
                        <div class="o_flow_props_actions">
                            <button class="btn btn-sm btn-primary w-100"
                                    t-on-click="() => this._openEditDialog(state.selectedNode.id)">
                                <i class="fa fa-pencil me-1"/>Edit Step
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_add_btn"
                                    t-on-click="() => this._openCreateDialog(state.selectedNode.id)">
                                <i class="fa fa-plus me-1"/>Add Child
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_delete_btn"
                                    t-on-click="() => this._confirmDelete(state.selectedNode.id, !!(state.selectedNode.children and state.selectedNode.children.length))">
                                <i class="fa fa-trash me-1"/>Delete
                            </button>
                        </div>
                    </t>
                    <t t-if="state.panelMode === 'props' and !state.selectedNode">
                        <div class="o_flow_props_empty">
                            <i class="fa fa-hand-pointer-o fa-2x mb-2"/>
                            <div>Click a node to inspect it</div>
                            <div class="mt-1 text-muted" style="font-size:10px;">Drag nodes to reposition</div>
                        </div>
                    </t>
                </div>

            </div>
        </div>
    </t>

</templates>
