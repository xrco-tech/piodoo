<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="comm_whatsapp_chatbot.ChatbotFlowAction">
        <div class="o_chatbot_flow_action">

            <!-- Toolbar -->
            <div class="o_chatbot_flow_toolbar">
                <div class="o_chatbot_flow_toolbar_left">
                    <button class="btn btn-sm btn-light o_flow_back_btn"
                            t-on-click="() => this._goBack()"
                            title="Back to chatbot details">
                        <i class="fa fa-chevron-left"/>
                    </button>
                    <button class="btn btn-sm btn-primary o_flow_add_step_btn"
                            t-on-click="() => this._openCreateDialog(false)"
                            title="Add a new top-level step">
                        Add Step
                    </button>
                    <span class="o_chatbot_flow_bot_icon">
                        <i class="fa fa-whatsapp"/>
                    </span>
                    <span class="o_chatbot_flow_title" t-esc="state.chatbotName"/>
                </div>
                <div class="o_chatbot_flow_toolbar_right">
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom - 0.1)">−</button>
                    <span class="o_flow_zoom_label" t-esc="zoomLabel"/>
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom + 0.1)">+</button>
                    <button class="btn btn-sm btn-light ms-2"
                            t-on-click="() => this._resetLayout()"
                            title="Reset to automatic tree layout">
                        <i class="fa fa-sitemap"/>
                    </button>
                </div>
            </div>

            <!-- Body: canvas + properties panel side-by-side -->
            <div class="o_chatbot_flow_body">

                <!-- Canvas area -->
                <div class="o_chatbot_flow_canvas_wrap">
                    <div t-if="state.loading" class="o_chatbot_flow_loading">
                        <div class="o_loading_spinner"/>
                    </div>
                    <div t-else="" class="o_chatbot_flow_canvas" t-ref="canvas"/>
                </div>

                <!-- Properties panel -->
                <div class="o_chatbot_flow_props" t-if="!state.loading">
                    <div class="o_flow_props_header">
                        <i class="fa fa-info-circle me-1"/>Properties
                    </div>
                    <t t-if="state.selectedNode">
                        <div class="o_flow_props_type_row">
                            <span class="o_flow_card_badge o_flow_props_badge"
                                  t-att-style="'background:' + typeCfg(state.selectedNode.type).color">
                                <t t-esc="typeCfg(state.selectedNode.type).icon"/>
                                <t t-esc="typeCfg(state.selectedNode.type).label"/>
                            </span>
                        </div>
                        <div class="o_flow_props_label">Name</div>
                        <div class="o_flow_props_value fw-semibold">
                            <t t-esc="state.selectedNode.name"/>
                        </div>
                        <t t-if="state.selectedNode.preview_html">
                            <div class="o_flow_props_label mt-2">Message</div>
                            <div class="o_flow_bubble o_flow_props_bubble"
                                 t-out="state.selectedNode.preview_html"/>
                        </t>
                        <t t-if="state.selectedNode.answers and state.selectedNode.answers.length">
                            <div class="o_flow_props_label mt-2">Trigger answers</div>
                            <div class="o_flow_chips">
                                <t t-foreach="state.selectedNode.answers" t-as="ans" t-key="ans_index">
                                    <span class="o_flow_chip"><t t-esc="ans"/></span>
                                </t>
                            </div>
                        </t>
                        <t t-if="state.selectedNode.children and state.selectedNode.children.length">
                            <div class="o_flow_props_label mt-2">Child steps</div>
                            <div class="o_flow_props_value">
                                <t t-esc="state.selectedNode.children.length"/>
                            </div>
                        </t>
                        <div class="o_flow_props_actions">
                            <button class="btn btn-sm btn-primary w-100"
                                    t-on-click="() => this._openEditDialog(state.selectedNode.id)">
                                <i class="fa fa-pencil me-1"/>Edit Step
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_add_btn"
                                    t-on-click="() => this._openCreateDialog(state.selectedNode.id)">
                                <i class="fa fa-plus me-1"/>Add Child
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_delete_btn"
                                    t-on-click="() => this._confirmDelete(state.selectedNode.id, !!(state.selectedNode.children and state.selectedNode.children.length))">
                                <i class="fa fa-trash me-1"/>Delete
                            </button>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="o_flow_props_empty">
                            <i class="fa fa-hand-pointer-o fa-2x mb-2"/>
                            <div>Click a node to inspect it</div>
                            <div class="mt-1 text-muted" style="font-size:10px;">Drag nodes to reposition</div>
                        </div>
                    </t>
                </div>

            </div>
        </div>
    </t>

</templates>
