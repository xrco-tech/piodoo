<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="comm_whatsapp_chatbot.ChatbotFlowAction">
        <div class="o_chatbot_flow_action">

            <!-- Toolbar -->
            <div class="o_chatbot_flow_toolbar">
                <div class="o_chatbot_flow_toolbar_left">
                    <button class="btn btn-sm btn-light o_flow_back_btn"
                            t-on-click="() => this._goBack()"
                            title="Back to chatbot details">
                        <i class="fa fa-chevron-left"/>
                    </button>
                    <button class="btn btn-sm btn-primary o_flow_add_step_btn"
                            t-on-click="() => this._openCreateDialog(false)"
                            title="Add a new top-level step">
                        Add Step
                    </button>
                    <span class="o_chatbot_flow_title" t-esc="state.chatbotName"/>
                </div>
                <div class="o_chatbot_flow_toolbar_right">
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom - 0.1)">−</button>
                    <span class="o_flow_zoom_label" t-esc="zoomLabel"/>
                    <button class="btn btn-sm btn-light o_flow_zoom_btn" t-on-click="() => this._setZoom(state.zoom + 0.1)">+</button>
                    <button class="btn btn-sm btn-light ms-2"
                            t-on-click="() => this._resetLayout()"
                            title="Reset to automatic tree layout">
                        <i class="fa fa-sitemap"/>
                    </button>
                </div>
            </div>

            <!-- Body: canvas + properties panel side-by-side -->
            <div class="o_chatbot_flow_body">

                <!-- Canvas area -->
                <div class="o_chatbot_flow_canvas_wrap">
                    <div t-if="state.loading" class="o_chatbot_flow_loading">
                        <div class="o_loading_spinner"/>
                    </div>
                    <div t-else="" class="o_chatbot_flow_canvas" t-ref="canvas"/>
                </div>

                <!-- Properties panel -->
                <div class="o_chatbot_flow_props" t-if="!state.loading">
                    <div class="o_flow_props_header">
                        <i class="fa fa-info-circle me-1"/>Properties
                    </div>
                    <t t-if="state.selectedNode">

                        <!-- Dead-end warning -->
                        <t t-if="state.selectedNode.isDeadEnd">
                            <div class="o_flow_props_warning">
                                <i class="fa fa-exclamation-triangle me-1"/>
                                <strong>Dead-end step</strong>
                                <div class="mt-1">This step has no child steps and is not a terminal node. Users will have no path forward. Add a child step, or change the type to <em>End Flow</em> or <em>Transfer to Agent</em>.</div>
                            </div>
                        </t>

                        <!-- Type badge -->
                        <div class="o_flow_props_type_row">
                            <span class="o_flow_card_badge o_flow_props_badge"
                                  t-att-style="'background:' + typeCfg(state.selectedNode.type).color">
                                <t t-esc="typeCfg(state.selectedNode.type).icon"/>
                                <t t-esc="typeCfg(state.selectedNode.type).label"/>
                            </span>
                        </div>

                        <!-- Name -->
                        <div class="o_flow_props_label">Name</div>
                        <div class="o_flow_props_value fw-semibold mb-2">
                            <t t-esc="state.selectedNode.name"/>
                        </div>

                        <!-- Sequence + WA delivery type (side by side) -->
                        <div class="o_flow_props_meta_row">
                            <div>
                                <div class="o_flow_props_label">Sequence</div>
                                <div class="o_flow_props_value">#<t t-esc="state.selectedNode.sequence"/></div>
                            </div>
                            <t t-if="state.selectedNode.waType and state.selectedNode.waType != 'non_interactive'">
                                <div>
                                    <div class="o_flow_props_label">Delivery</div>
                                    <span class="o_flow_props_wa_badge"
                                          t-att-style="'background:' + waTypeBadgeColor(state.selectedNode.waType)">
                                        <t t-esc="waTypeLabel(state.selectedNode.waType)"/>
                                    </span>
                                </div>
                            </t>
                            <t t-else="">
                                <div>
                                    <div class="o_flow_props_label">Delivery</div>
                                    <div class="o_flow_props_value">Plain</div>
                                </div>
                            </t>
                        </div>

                        <!-- Message preview -->
                        <t t-if="state.selectedNode.preview_html">
                            <div class="o_flow_props_label mt-2">Message</div>
                            <div class="o_flow_bubble o_flow_props_bubble"
                                 t-out="state.selectedNode.preview_html"/>
                        </t>

                        <!-- Header -->
                        <t t-if="state.selectedNode.headerType">
                            <div class="o_flow_props_label mt-2">Header</div>
                            <div class="o_flow_props_value o_flow_props_icon_row">
                                <i t-att-class="'fa ' + headerTypeIcon(state.selectedNode.headerType)"/>
                                <t t-esc="headerTypeLabel(state.selectedNode.headerType)"/>
                                <t t-if="state.selectedNode.headerType == 'text' and state.selectedNode.headerText">
                                    — <em><t t-esc="state.selectedNode.headerText"/></em>
                                </t>
                            </div>
                        </t>

                        <!-- Footer -->
                        <t t-if="state.selectedNode.footer">
                            <div class="o_flow_props_label mt-2">Footer</div>
                            <div class="o_flow_props_value o_flow_props_footer_val">
                                <t t-esc="state.selectedNode.footer"/>
                            </div>
                        </t>

                        <!-- Answer type (question steps) -->
                        <t t-if="isQuestionType(state.selectedNode.type) and state.selectedNode.answerDataType">
                            <div class="o_flow_props_label mt-2">Expected Answer</div>
                            <div class="o_flow_props_value">
                                <t t-esc="answerTypeLabel(state.selectedNode.answerDataType)"/>
                            </div>
                        </t>

                        <!-- Reply buttons -->
                        <t t-if="state.selectedNode.waType == 'interactive_button' and state.selectedNode.buttons.length">
                            <div class="o_flow_props_label mt-2">Reply Buttons</div>
                            <div class="o_flow_props_ia_list">
                                <t t-foreach="state.selectedNode.buttons" t-as="btn" t-key="btn_index">
                                    <div class="o_flow_props_ia_item"><t t-esc="btn"/></div>
                                </t>
                            </div>
                        </t>

                        <!-- List rows -->
                        <t t-if="state.selectedNode.waType == 'interactive_list'">
                            <div class="o_flow_props_label mt-2">List</div>
                            <div class="o_flow_props_value o_flow_props_icon_row">
                                <i class="fa fa-list-ul"/>
                                <t t-esc="state.selectedNode.listBtnText"/>
                            </div>
                            <t t-if="state.selectedNode.listRows.length">
                                <div class="o_flow_props_ia_list">
                                    <t t-foreach="state.selectedNode.listRows" t-as="row" t-key="row_index">
                                        <div class="o_flow_props_ia_item"><t t-esc="row"/></div>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- Interactive flow -->
                        <t t-if="state.selectedNode.waType == 'interactive_flow'">
                            <div class="o_flow_props_label mt-2">Flow</div>
                            <t t-if="state.selectedNode.flowName">
                                <div class="o_flow_props_value o_flow_props_icon_row">
                                    <i class="fa fa-bolt"/>
                                    <t t-esc="state.selectedNode.flowName"/>
                                </div>
                            </t>
                            <t t-if="state.selectedNode.flowCta">
                                <div class="o_flow_props_label mt-1">CTA</div>
                                <div class="o_flow_props_value o_flow_props_flow_cta">
                                    <t t-esc="state.selectedNode.flowCta"/>
                                </div>
                            </t>
                        </t>

                        <!-- Retry / fallback (question steps) -->
                        <t t-if="isQuestionType(state.selectedNode.type)">
                            <div class="o_flow_props_label mt-2">Max Retries</div>
                            <div class="o_flow_props_value"><t t-esc="state.selectedNode.maxRetries"/></div>
                            <t t-if="state.selectedNode.fallbackStepName">
                                <div class="o_flow_props_label mt-1">Fallback Step</div>
                                <div class="o_flow_props_value o_flow_props_icon_row">
                                    <i class="fa fa-share-square-o"/>
                                    <t t-esc="state.selectedNode.fallbackStepName"/>
                                </div>
                            </t>
                        </t>

                        <!-- Variable (set_variable steps) -->
                        <t t-if="state.selectedNode.type == 'set_variable' and state.selectedNode.variableName">
                            <div class="o_flow_props_label mt-2">Variable</div>
                            <div class="o_flow_props_value fw-semibold">
                                <t t-esc="state.selectedNode.variableName"/>
                            </div>
                            <t t-if="state.selectedNode.variableDataSource">
                                <div class="o_flow_props_label mt-1">Source</div>
                                <div class="o_flow_props_value">
                                    <t t-esc="varSourceLabel(state.selectedNode.variableDataSource, state.selectedNode)"/>
                                </div>
                            </t>
                        </t>

                        <!-- Trigger answers -->
                        <t t-if="state.selectedNode.answers and state.selectedNode.answers.length">
                            <div class="o_flow_props_label mt-2">Trigger Conditions</div>
                            <div class="o_flow_chips">
                                <t t-foreach="state.selectedNode.answers" t-as="ans" t-key="ans_index">
                                    <span class="o_flow_chip"><t t-esc="ans"/></span>
                                </t>
                            </div>
                        </t>

                        <!-- Child steps count -->
                        <t t-if="state.selectedNode.children and state.selectedNode.children.length">
                            <div class="o_flow_props_label mt-2">Child Steps</div>
                            <div class="o_flow_props_value">
                                <t t-esc="state.selectedNode.children.length"/>
                            </div>
                        </t>

                        <!-- Actions -->
                        <div class="o_flow_props_actions">
                            <button class="btn btn-sm btn-primary w-100"
                                    t-on-click="() => this._openEditDialog(state.selectedNode.id)">
                                <i class="fa fa-pencil me-1"/>Edit Step
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_add_btn"
                                    t-on-click="() => this._openCreateDialog(state.selectedNode.id)">
                                <i class="fa fa-plus me-1"/>Add Child
                            </button>
                            <button class="btn btn-sm w-100 o_flow_props_delete_btn"
                                    t-on-click="() => this._confirmDelete(state.selectedNode.id, !!(state.selectedNode.children and state.selectedNode.children.length))">
                                <i class="fa fa-trash me-1"/>Delete
                            </button>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="o_flow_props_empty">
                            <i class="fa fa-hand-pointer-o fa-2x mb-2"/>
                            <div>Click a node to inspect it</div>
                            <div class="mt-1 text-muted" style="font-size:10px;">Drag nodes to reposition</div>
                        </div>
                    </t>
                </div>

            </div>
        </div>
    </t>

</templates>
