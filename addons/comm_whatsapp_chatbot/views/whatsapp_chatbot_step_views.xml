<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- WhatsApp Chatbot Step Search View -->
        <record id="view_whatsapp_chatbot_step_search" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.step.search</field>
            <field name="model">whatsapp.chatbot.step</field>
            <field name="arch" type="xml">
                <search string="Search Steps">
                    <field name="name"/>
                    <field name="chatbot_id"/>
                    <field name="step_type"/>
                    <separator/>
                    <filter string="Root Steps" name="root_steps" domain="[('parent_id', '=', False)]"/>
                    <filter string="Messages" name="messages" domain="[('step_type', '=', 'message')]"/>
                    <filter string="Questions" name="questions" domain="[('step_type', 'like', 'question%')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Chatbot" name="group_chatbot" context="{'group_by': 'chatbot_id'}"/>
                        <filter string="Step Type" name="group_step_type" context="{'group_by': 'step_type'}"/>
                        <filter string="Parent" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- WhatsApp Chatbot Step List View -->
        <record id="view_whatsapp_chatbot_step_tree" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.step.tree</field>
            <field name="model">whatsapp.chatbot.step</field>
            <field name="arch" type="xml">
                <list string="Chatbot Steps" default_order="sequence asc">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="chatbot_id"/>
                    <field name="step_type"/>
                    <field name="parent_id" string="Parent Step"/>
                    <field name="body_plain" optional="hide"/>
                </list>
            </field>
        </record>

        <!-- WhatsApp Chatbot Step Form View -->
        <record id="view_whatsapp_chatbot_step_form" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.step.form</field>
            <field name="model">whatsapp.chatbot.step</field>
            <field name="arch" type="xml">
                <form string="Chatbot Step">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="chatbot_id"/>
                                <field name="sequence"/>
                                <field name="step_type"/>
                                <field name="parent_id" string="Parent Step"/>
                            </group>
                            <group>
                                <field name="wa_message_type" invisible="step_type in ['set_variable', 'execute_code', 'transfer_to_agent', 'jump_to_flow', 'end_flow'] or chatbot_id.channel in ['sms', 'ussd']"/>
                                <field name="answer_data_type" invisible="step_type not in ['question_text', 'question_numeric', 'question_phone', 'question_email', 'question_date']"/>
                                <field name="max_retries" invisible="step_type not in ['question_text', 'question_numeric', 'question_phone', 'question_email', 'question_date', 'question_document', 'question_image', 'question_video', 'question_audio', 'question_interactive']"/>
                                <field name="fallback_step_id" invisible="step_type not in ['question_text', 'question_numeric', 'question_phone', 'question_email', 'question_date', 'question_document', 'question_image', 'question_video', 'question_audio', 'question_interactive']"/>
                            </group>
                        </group>
                        
                        <notebook>
                            <page string="Message Content" name="content" invisible="step_type in ['set_variable', 'execute_code', 'transfer_to_agent', 'jump_to_flow', 'end_flow']">
                                <group>
                                    <group string="Body">
                                        <field name="body_plain" widget="text" nolabel="1" placeholder="Enter message body..."/>
                                        <div class="alert alert-info" role="alert" invisible="not body_plain">
                                            <p><strong>Preview:</strong> Markdown formatting (*bold*, _italic_, ~strikethrough~, ```code```) will be applied in the message.</p>
                                        </div>
                                        <field name="body_html" widget="html" nolabel="1" readonly="1" invisible="not body_plain" string="Formatted Preview"/>
                                    </group>
                                </group>
                                
                                <group string="Header &amp; Footer">
                                    <group>
                                        <field name="header_type"/>
                                        <field name="header_text" invisible="header_type != 'text'"/>
                                        <field name="attachment_id" invisible="header_type not in ['document', 'image', 'video']"/>
                                    </group>
                                    <group>
                                        <field name="footer"/>
                                    </group>
                                </group>
                                
                                <group string="Interactive Elements" invisible="wa_message_type == 'non_interactive'">
                                    <!-- Interactive Reply Buttons -->
                                    <field name="button_ids" invisible="wa_message_type != 'interactive_button'" nolabel="1">
                                        <list editable="bottom" create="1" delete="1">
                                            <field name="sequence" widget="handle"/>
                                            <field name="button_id" string="Button ID" placeholder="e.g. btn_1"/>
                                            <field name="title" string="Label" placeholder="Button text (max 20 chars)"/>
                                            <field name="description" string="Description" optional="show"/>
                                        </list>
                                    </field>
                                    <div class="text-muted small" invisible="wa_message_type != 'interactive_button'">
                                        WhatsApp allows a maximum of 3 reply buttons per message.
                                    </div>

                                    <!-- Interactive List -->
                                    <field name="list_button_text" invisible="wa_message_type != 'interactive_list'"/>
                                    <field name="list_row_ids" invisible="wa_message_type != 'interactive_list'" nolabel="1">
                                        <list editable="bottom" create="1" delete="1">
                                            <field name="sequence" widget="handle"/>
                                            <field name="section" string="Section" placeholder="Section heading (optional)"/>
                                            <field name="row_id" string="Row ID" placeholder="e.g. row_1"/>
                                            <field name="title" string="Title" placeholder="Option text (max 24 chars)"/>
                                            <field name="description" string="Description" optional="show" placeholder="Optional subtitle"/>
                                        </list>
                                    </field>
                                    <div class="text-muted small" invisible="wa_message_type != 'interactive_list'">
                                        WhatsApp allows up to 10 rows across all sections.
                                    </div>
                                </group>
                                
                                <group string="Flow Integration" invisible="wa_message_type != 'interactive_flow' or chatbot_id.channel != 'whatsapp'">
                                    <field name="flow_id" domain="[('status', '=', 'PUBLISHED')]"/>
                                    <field name="flow_uid" readonly="1"/>
                                    <field name="flow_action"/>
                                    <field name="screen_id" string="Entry Screen ID"/>
                                    <field name="flow_cta" string="CTA Text"/>
                                    <field name="screen_payload_data" widget="json"/>
                                </group>
                            </page>
                            
                            <page string="Variable Settings" name="variable" invisible="step_type != 'set_variable'">
                                <group>
                                    <field name="variable_id"/>
                                    <field name="variable_data_source"/>
                                    <field name="source_step_id" invisible="variable_data_source != 'answer'"/>
                                    <field name="source_variable_id" invisible="variable_data_source != 'variable'"/>
                                    <field name="variable_value" invisible="variable_data_source != 'static'"/>
                                </group>
                            </page>
                            
                            <page string="Transfer to Agent" name="transfer" invisible="step_type != 'transfer_to_agent'">
                                <group>
                                    <field name="body_plain" widget="text" string="Handover Message" nolabel="1"
                                           placeholder="Message shown to the user before transferring, e.g. 'Connecting you to an agent...'"/>
                                </group>
                                <group string="Agent Routing">
                                    <field name="agent_partner_ids" widget="many2many_tags"
                                           placeholder="Leave empty to use chatbot defaults"/>
                                </group>
                            </page>

                            <page string="Code Execution" name="code" invisible="step_type != 'execute_code'">
                                <group>
                                    <field name="code" widget="text" nolabel="1" placeholder="Write Python code here..."/>
                                </group>
                            </page>

                            <page string="Jump to Flow/Bot" name="jump" invisible="step_type != 'jump_to_flow'">
                                <group>
                                    <group string="Target">
                                        <field name="chatbot_channel" invisible="1"/>
                                        <field name="target_chatbot_id"
                                               options="{'no_create': True}"
                                               domain="[('channel', '=', chatbot_channel)]"
                                               placeholder="Pick a chatbot to jump into"/>
                                        <field name="target_step_id"
                                               options="{'no_create': True}"
                                               placeholder="Leave empty for root step"/>
                                        <field name="jump_mode" widget="radio"/>
                                    </group>
                                </group>
                                <group string="Variable Mapping">
                                    <field name="variable_mapping_ids" nolabel="1">
                                        <list editable="bottom" create="1" delete="1">
                                            <field name="sequence" widget="handle"/>
                                            <field name="source_chatbot_id" column_invisible="1"/>
                                            <field name="target_chatbot_id" column_invisible="1"/>
                                            <field name="source_variable_id"
                                                   options="{'no_create': True}"/>
                                            <field name="target_variable_id"
                                                   options="{'no_create': True}"/>
                                            <field name="direction"/>
                                        </list>
                                    </field>
                                    <div class="text-muted small">
                                        <strong>In</strong> copies caller → callee on jump.
                                        <strong>Out</strong> copies callee → caller on return (subroutine only).
                                        <strong>Both</strong> does each side.
                                    </div>
                                </group>
                            </page>
                            
                            <page string="Live Agent Assist" name="agent_assist">
                                <group>
                                    <group string="Coaching Notes">
                                        <field name="coaching_notes" nolabel="1" widget="text"
                                               placeholder="Behavioral tips shown to the agent. e.g. 'Empathy check: lower tone if customer says broken.'"/>
                                    </group>
                                    <group string="CRM Action">
                                        <field name="crm_action" nolabel="1" widget="text"
                                               placeholder="Explicit instructions. e.g. '[Pull up order in OMS, paste tracking number into chat]'"/>
                                    </group>
                                </group>
                                <div class="text-muted small">
                                    Both fields render as inline call-outs in the simulator (and the
                                    future Agent Workspace for Voice Call bots) next to the step body.
                                    Leave empty to hide. Useful on any channel — particularly handy
                                    for live-script flows where the agent reads the body to a customer.
                                </div>
                            </page>

                            <page string="Child Steps" name="children">
                                <field name="child_ids" nolabel="1">
                                    <list create="1" delete="1" edit="1" editable="bottom" default_order="sequence asc">
                                        <field name="id" column_invisible="1"/>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="step_type"/>
                                        <field name="trigger_answer_ids" widget="many2many_tags" optional="show" options="{'no_create': False}" context="{'default_step_id': id}"/>
                                        <field name="trigger_variable_ids" widget="many2many_tags" optional="show" options="{'no_create': False}" context="{'default_step_id': id}"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- WhatsApp Chatbot Step Action -->
        <record id="action_whatsapp_chatbot_step" model="ir.actions.act_window">
            <field name="name">Chatbot Steps</field>
            <field name="res_model">whatsapp.chatbot.step</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_whatsapp_chatbot_step_search"/>
        </record>
    </data>
</odoo>
