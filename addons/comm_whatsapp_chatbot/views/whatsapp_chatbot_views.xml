<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- WhatsApp Chatbot Search View -->
        <record id="view_whatsapp_chatbot_search" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.search</field>
            <field name="model">whatsapp.chatbot</field>
            <field name="arch" type="xml">
                <search string="Search Chatbots">
                    <field name="name"/>
                    <field name="description"/>
                    <separator/>
                    <filter string="Draft" name="status_draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="Published" name="status_published" domain="[('status', '=', 'published')]"/>
                    <filter string="Inactive" name="status_inactive" domain="[('status', '=', 'inactive')]"/>
                    <separator/>
                    <filter string="Active Users" name="has_contacts" domain="[('chatbot_contact_count', '>', 0)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- WhatsApp Chatbot List View -->
        <record id="view_whatsapp_chatbot_tree" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.tree</field>
            <field name="model">whatsapp.chatbot</field>
            <field name="arch" type="xml">
                <list string="WhatsApp Chatbots">
                    <field name="name"/>
                    <field name="status" widget="badge"
                        decoration-success="status == 'published'"
                        decoration-warning="status == 'draft'"
                        decoration-danger="status == 'inactive'"/>
                    <field name="description"/>
                    <field name="step_count" widget="statinfo" string="Steps"/>
                    <field name="chatbot_contact_count" widget="statinfo" string="Active Users"/>
                    <field name="chatbot_message_count" widget="statinfo" string="Messages"/>
                </list>
            </field>
        </record>

        <!-- WhatsApp Chatbot Kanban View -->
        <record id="view_whatsapp_chatbot_kanban" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.kanban</field>
            <field name="model">whatsapp.chatbot</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="status"/>
                    <field name="step_count"/>
                    <field name="chatbot_contact_count"/>
                    <field name="chatbot_message_count"/>
                    <field name="description"/>
                    <templates>
                        <t t-name="card">
                            <div class="fw-bold mb-1">
                                <field name="name"/>
                            </div>
                            <t t-if="record.description.value">
                                <div class="text-muted small mb-2">
                                    <t t-esc="record.description.value"/>
                                </div>
                            </t>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge rounded-pill text-bg-secondary">
                                    <i class="fa fa-sitemap me-1"/>
                                    <t t-esc="record.step_count.value"/> Steps
                                </span>
                                <span class="badge rounded-pill text-bg-info">
                                    <i class="fa fa-users me-1"/>
                                    <t t-esc="record.chatbot_contact_count.value"/> Users
                                </span>
                                <span class="badge rounded-pill text-bg-success">
                                    <i class="fa fa-comments me-1"/>
                                    <t t-esc="record.chatbot_message_count.value"/> Msgs
                                </span>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- WhatsApp Chatbot Form View -->
        <record id="view_whatsapp_chatbot_form" model="ir.ui.view">
            <field name="name">whatsapp.chatbot.form</field>
            <field name="model">whatsapp.chatbot</field>
            <field name="arch" type="xml">
                <form string="WhatsApp Chatbot">
                    <header>
                        <button name="action_publish"
                                type="object"
                                string="Publish"
                                class="btn-primary"
                                invisible="status == 'published'"/>
                        <button name="action_deactivate"
                                type="object"
                                string="Deactivate"
                                invisible="status != 'published'"/>
                        <button name="action_reset_to_draft"
                                type="object"
                                string="Reset to Draft"
                                invisible="status != 'inactive'"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,published,inactive"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_active_users"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-users"
                                    invisible="chatbot_contact_count == 0">
                                <field name="chatbot_contact_count" widget="statinfo" string="Active Users"/>
                            </button>
                            <button name="action_view_historical_users"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-user-plus"
                                    invisible="historical_contact_count == 0">
                                <field name="historical_contact_count" widget="statinfo" string="Total Users"/>
                            </button>
                            <button name="action_view_messages"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-comments"
                                    invisible="chatbot_message_count == 0">
                                <field name="chatbot_message_count" widget="statinfo" string="Messages"/>
                            </button>
                            <button name="action_view_step_hierarchy"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-code-fork">
                                <field name="step_count" widget="statinfo" string="Flow"/>
                            </button>
                        </div>

                        <group>
                            <group string="Basic Information">
                                <field name="name"/>
                                <field name="description" widget="text"/>
                            </group>
                            <group string="Keywords and Variables">
                                <field name="bot_trigger_ids" widget="many2many_tags" string="Triggers"
                                       context="{'default_chatbot_id': id}"/>
                                <field name="bot_variable_ids" widget="many2many_tags" string="Variables"
                                       context="{'default_chatbot_id': id}"/>
                            </group>
                        </group>
                        <group>
                            <group string="Default Messages">
                                <field name="default_confusion_message" widget="text"/>
                                <field name="default_error_message" widget="text"/>
                            </group>
                            <group string="Context Resources">
                                <field name="context_pdf"/>
                                <field name="context_url"/>
                                <field name="context_data" widget="text" readonly="1"/>
                            </group>
                        </group>
                        <group string="Global Interrupt Keywords">
                            <div class="text-muted small mb-2" style="grid-column: 1 / -1">
                                Keywords that can interrupt any step — e.g. "cancel", "menu", "human". Matched case-insensitively.
                            </div>
                            <field name="global_interrupt_ids" nolabel="1" colspan="2">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="keyword"/>
                                    <field name="action"/>
                                    <field name="target_step_id"
                                           context="{'default_chatbot_id': id}"
                                           invisible="action != 'goto_step'"/>
                                    <field name="response_message" optional="show"/>
                                </list>
                            </field>
                        </group>

                        <group>
                            <group string="AI Agent Setup">
                                <field name="ai_agent_header"/>
                                <field name="ai_agent_footer"/>
                                <field name="ai_agent_prompt_text" widget="text"/>
                                <field name="ai_agent_rtc_button_label"/>
                            </group>
                            <group string="External Agent Setup">
                                <field name="forward_to_external_agent"/>
                                <field name="external_agent_partner_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- WhatsApp Chatbot Action -->
        <record id="action_whatsapp_chatbot" model="ir.actions.act_window">
            <field name="name">Chatbots</field>
            <field name="res_model">whatsapp.chatbot</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_group_by_status': 1}</field>
            <field name="search_view_id" ref="view_whatsapp_chatbot_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first chatbot!
                </p>
                <p>
                    Build conversational flows to automate WhatsApp messaging and engage with customers.
                </p>
            </field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_whatsapp_chatbots"
                  name="Chatbots"
                  parent="comm_whatsapp.menu_whatsapp_root"
                  action="action_whatsapp_chatbot"
                  sequence="40"/>
    </data>
</odoo>
