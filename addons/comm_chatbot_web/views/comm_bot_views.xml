<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_comm_bot_form_web" model="ir.ui.view">
        <field name="name">comm.bot.form.web</field>
        <field name="model">comm.bot</field>
        <field name="inherit_id" ref="comm_chatbot.view_comm_bot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_web_embed_code"
                        type="object" string="Copy embed code"
                        invisible="not entry_step_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Web widget">
                    <group>
                        <field name="web_allowed_domains"
                               placeholder="https://example.com&#10;https://www.example.com"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
