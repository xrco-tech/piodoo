<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_comm_bot_web_session_list" model="ir.ui.view">
        <field name="name">comm.bot.web.session.list</field>
        <field name="model">comm.bot.web.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="created_at"/>
                <field name="bot_id"/>
                <field name="token"/>
                <field name="conversation_id"/>
                <field name="partner_id"/>
                <field name="referer"/>
                <field name="last_activity_at"/>
                <field name="closed"/>
                <field name="is_preview"/>
            </list>
        </field>
    </record>

    <record id="action_comm_bot_web_session" model="ir.actions.act_window">
        <field name="name">Web Sessions</field>
        <field name="res_model">comm.bot.web.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_comm_bot_web_session"
              name="Web Sessions"
              parent="comm_chatbot.menu_comm_chatbot_config"
              action="action_comm_bot_web_session"
              sequence="60"/>

</odoo>
