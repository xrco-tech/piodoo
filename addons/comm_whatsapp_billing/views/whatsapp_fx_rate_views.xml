<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_fx_rate_list" model="ir.ui.view">
        <field name="name">whatsapp.fx.rate.list</field>
        <field name="model">whatsapp.fx.rate</field>
        <field name="arch" type="xml">
            <list editable="bottom" string="Meta Monthly Billing FX">
                <field name="date" string="Month"/>
                <field name="currency_id"/>
                <field name="rate" string="USD → local"/>
                <field name="source"/>
            </list>
        </field>
    </record>

    <record id="action_whatsapp_fx_rate" model="ir.actions.act_window">
        <field name="name">Meta Monthly Billing FX</field>
        <field name="res_model">whatsapp.fx.rate</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Meta bills your WABA in your currency using their own monthly FX rate.
                Add a row per month to reconcile the ledger against Meta's invoice.
            </p>
            <p>
                Leave this table empty to fall back to Odoo's live currency rates
                (Accounting → Currencies), or the account's default FX rate.
            </p>
        </field>
    </record>

</odoo>
