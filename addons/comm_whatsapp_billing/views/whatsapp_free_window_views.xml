<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_free_window_list" model="ir.ui.view">
        <field name="name">whatsapp.free.window.list</field>
        <field name="model">whatsapp.free.window</field>
        <field name="arch" type="xml">
            <list>
                <field name="wa_id"/>
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="window_type"/>
                <field name="opened_at"/>
                <field name="expires_at"/>
            </list>
        </field>
    </record>

    <record id="action_whatsapp_free_window" model="ir.actions.act_window">
        <field name="name">Free Windows</field>
        <field name="res_model">whatsapp.free.window</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
