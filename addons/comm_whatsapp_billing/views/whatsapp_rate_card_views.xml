<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_rate_card_list" model="ir.ui.view">
        <field name="name">whatsapp.rate.card.list</field>
        <field name="model">whatsapp.rate.card</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="billing_model"/>
                <field name="effective_from"/>
                <field name="effective_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_rate_card_form" model="ir.ui.view">
        <field name="name">whatsapp.rate.card.form</field>
        <field name="model">whatsapp.rate.card</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="billing_model"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="effective_from"/>
                            <field name="effective_to"/>
                            <field name="service_free_in_cs_window"/>
                            <field name="utility_free_in_cs_window"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rates">
                            <field name="rate_ids">
                                <list editable="bottom">
                                    <field name="country_id"/>
                                    <field name="category"/>
                                    <field name="unit"/>
                                    <field name="price_usd"/>
                                    <field name="tier_from"/>
                                    <field name="tier_to"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_whatsapp_rate_card" model="ir.actions.act_window">
        <field name="name">Rate Cards</field>
        <field name="res_model">whatsapp.rate.card</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
