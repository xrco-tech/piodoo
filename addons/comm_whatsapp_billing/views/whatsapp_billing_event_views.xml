<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_whatsapp_billing_event_list" model="ir.ui.view">
        <field name="name">whatsapp.billing.event.list</field>
        <field name="model">whatsapp.billing.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="event_date"/>
                <field name="account_id"/>
                <field name="wa_id"/>
                <field name="country_id"/>
                <field name="category"/>
                <field name="unit"/>
                <field name="unit_qty"/>
                <field name="price_usd" sum="Total USD"/>
                <field name="price_local" sum="Total local"/>
                <field name="currency_id"/>
                <field name="is_free"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_billing_event_form" model="ir.ui.view">
        <field name="name">whatsapp.billing.event.form</field>
        <field name="model">whatsapp.billing.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="event_date"/>
                            <field name="account_id"/>
                            <field name="partner_id"/>
                            <field name="wa_id"/>
                            <field name="country_id"/>
                            <field name="campaign_id"/>
                        </group>
                        <group>
                            <field name="category"/>
                            <field name="unit"/>
                            <field name="unit_qty"/>
                            <field name="rate_card_id"/>
                            <field name="rate_id"/>
                            <field name="is_free"/>
                            <field name="free_reason" invisible="not is_free"/>
                        </group>
                    </group>
                    <group string="Amounts">
                        <group>
                            <field name="price_usd"/>
                            <field name="fx_rate"/>
                        </group>
                        <group>
                            <field name="price_local"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Source">
                        <field name="source_model"/>
                        <field name="source_id"/>
                        <field name="message_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_billing_event_pivot" model="ir.ui.view">
        <field name="name">whatsapp.billing.event.pivot</field>
        <field name="model">whatsapp.billing.event</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="category" type="row"/>
                <field name="country_id" type="col"/>
                <field name="price_usd" type="measure"/>
                <field name="price_local" type="measure"/>
                <field name="unit_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_whatsapp_billing_event_graph" model="ir.ui.view">
        <field name="name">whatsapp.billing.event.graph</field>
        <field name="model">whatsapp.billing.event</field>
        <field name="arch" type="xml">
            <graph type="line" sample="1">
                <field name="event_date" interval="day"/>
                <field name="price_usd" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_whatsapp_billing_event_search" model="ir.ui.view">
        <field name="name">whatsapp.billing.event.search</field>
        <field name="model">whatsapp.billing.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="wa_id"/>
                <field name="account_id"/>
                <field name="country_id"/>
                <field name="category"/>
                <field name="campaign_id"/>
                <filter string="Free (windows)" name="free"
                        domain="[('is_free', '=', True)]"/>
                <filter string="Paid" name="paid"
                        domain="[('is_free', '=', False), ('price_usd', '>', 0)]"/>
                <filter string="This month" name="this_month"
                        domain="[('event_date', '>=', time.strftime('%Y-%m-01'))]"/>
                <filter string="Last 7 days" name="last_7"
                        domain="[('event_date', '>=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group by">
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category'}"/>
                    <filter string="Country" name="group_country"
                            context="{'group_by': 'country_id'}"/>
                    <filter string="Account" name="group_account"
                            context="{'group_by': 'account_id'}"/>
                    <filter string="Campaign" name="group_campaign"
                            context="{'group_by': 'campaign_id'}"/>
                    <filter string="Day" name="group_day"
                            context="{'group_by': 'event_date:day'}"/>
                    <filter string="Month" name="group_month"
                            context="{'group_by': 'event_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_whatsapp_billing_event" model="ir.actions.act_window">
        <field name="name">Billing Events</field>
        <field name="res_model">whatsapp.billing.event</field>
        <field name="view_mode">list,graph,pivot,form</field>
        <field name="context">{'search_default_this_month': 1, 'search_default_group_category': 1}</field>
    </record>

    <record id="action_whatsapp_billing_dashboard" model="ir.actions.act_window">
        <field name="name">Cost Dashboard</field>
        <field name="res_model">whatsapp.billing.event</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="context">{'search_default_this_month': 1, 'search_default_group_category': 1}</field>
    </record>

</odoo>
