<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Per-message pricing model (Meta, effective 2025-07-01) -->
        <record id="rate_card_2025_jul" model="whatsapp.rate.card">
            <field name="name">Meta rates — Jul 2025 (per-message)</field>
            <field name="effective_from">2025-07-01</field>
            <field name="effective_to">2026-07-31</field>
            <field name="billing_model">per_message_2025</field>
            <field name="service_free_in_cs_window" eval="True"/>
            <field name="utility_free_in_cs_window" eval="True"/>
            <field name="notes">Per-message billing. Service messages free. Utility templates free inside 24h CS window.</field>
        </record>

        <!-- Hybrid model (Aug 2026): per-message + MBA tokens -->
        <record id="rate_card_2026_aug" model="whatsapp.rate.card">
            <field name="name">Meta rates — Aug 2026 (hybrid + MBA tokens)</field>
            <field name="effective_from">2026-08-01</field>
            <field name="effective_to">2026-09-30</field>
            <field name="billing_model">hybrid_2026</field>
            <field name="service_free_in_cs_window" eval="True"/>
            <field name="utility_free_in_cs_window" eval="True"/>
            <field name="notes">Adds MBA token pricing ($2/M tokens global). Non-MBA service messages still free until Oct 1.</field>
        </record>

        <!-- Oct 2026: service messages become paid outside MBA -->
        <record id="rate_card_2026_oct" model="whatsapp.rate.card">
            <field name="name">Meta rates — Oct 2026 (hybrid + paid service)</field>
            <field name="effective_from">2026-10-01</field>
            <field name="billing_model">hybrid_service_paid</field>
            <field name="service_free_in_cs_window" eval="False"/>
            <field name="utility_free_in_cs_window" eval="True"/>
            <field name="notes">Non-template service messages billed like utility/authentication. Utility templates keep the CS-window exemption.</field>
        </record>

    </data>
</odoo>
