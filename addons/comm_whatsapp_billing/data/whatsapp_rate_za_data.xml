<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            South Africa rates.
            Source: Meta WhatsApp Business Platform per-message rates,
            effective 2025-07-01. USD figures aggregated from public 2026
            rate-card summaries; verify against Meta's official CSV before
            invoicing.
        -->

        <!-- ============ Jul 2025 per-message card ============ -->

        <record id="rate_za_2025_marketing" model="whatsapp.rate">
            <field name="card_id" ref="rate_card_2025_jul"/>
            <field name="country_id" ref="base.za"/>
            <field name="category">marketing</field>
            <field name="unit">message</field>
            <field name="price_usd">0.0379</field>
        </record>

        <record id="rate_za_2025_utility" model="whatsapp.rate">
            <field name="card_id" ref="rate_card_2025_jul"/>
            <field name="country_id" ref="base.za"/>
