<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_comm_whatsapp_account_tree" model="ir.ui.view">
            <field name="name">comm.whatsapp.account.tree</field>
            <field name="model">comm.whatsapp.account</field>
            <field name="arch" type="xml">
                <list string="WhatsApp Accounts" default_order="sequence, id">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="phone_number"/>
                    <field name="phone_number_id"/>
                    <field name="business_account_id" optional="hide"/>
                    <field name="is_default" widget="boolean_toggle"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_comm_whatsapp_account_form" model="ir.ui.view">
            <field name="name">comm.whatsapp.account.form</field>
            <field name="model">comm.whatsapp.account</field>
            <field name="arch" type="xml">
                <form string="WhatsApp Account">
                    <header>
                        <button name="action_sync_flows" type="object"
                                string="Sync Flows" icon="fa-download"
                                class="btn-primary"
                                help="Pull all Flows from Meta for this WABA and rebuild the structured records."/>
                        <button name="action_sync_templates" type="object"
                                string="Sync Templates" icon="fa-download"
                                class="btn-primary"
                                help="Pull all message templates from Meta for this WABA."/>
                        <button name="action_refresh_from_meta" type="object"
                                string="Refresh from Meta" icon="fa-refresh"
                                class="btn-secondary"
                                help="Look up the phone_number_id on Meta and update the display phone number + verified name."/>
                        <button name="action_diagnose_calling" type="object"
                                string="Diagnose Calling" icon="fa-stethoscope"
                                class="btn-secondary"
                                help="Check whether Business Calling API and the calls webhook are set up correctly on Meta's side."/>
                        <button name="action_fix_base_url_to_https" type="object"
                                string="Force HTTPS Base URL" icon="fa-lock"
                                class="btn-secondary"
                                help="Rewrite web.base.url from http:// to https:// and freeze it, so Meta callbacks and email links stop leaking the plain-text host."/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_flows" type="object"
                                    class="oe_stat_button" icon="fa-code-fork">
                                <field name="flow_count" widget="statinfo" string="Flows"/>
                            </button>
                            <button name="action_view_templates" type="object"
                                    class="oe_stat_button" icon="fa-file-text-o">
                                <field name="template_count" widget="statinfo" string="Templates"/>
                            </button>
                            <button name="action_view_messages" type="object"
                                    class="oe_stat_button" icon="fa-comments">
                                <field name="message_count" widget="statinfo" string="Messages"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Support Line"/></h1>
                        </div>
                        <group>
                            <group string="Number">
                                <field name="phone_number" placeholder="+27693808740"/>
                                <field name="phone_number_id" placeholder="447501465113088"/>
                                <field name="business_account_id" placeholder="WABA ID (optional)"/>
                                <field name="verified_name" readonly="1"/>
                                <field name="quality_rating" readonly="1"
                                       widget="badge"
                                       decoration-success="quality_rating == 'GREEN'"
                                       decoration-warning="quality_rating == 'YELLOW'"
                                       decoration-danger="quality_rating == 'RED'"/>
                                <field name="last_verified_at" readonly="1"/>
                            </group>
                            <group string="Routing">
                                <field name="is_default"/>
                                <field name="active" invisible="1"/>
                                <field name="sequence"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Credentials" name="credentials">
                                <group>
                                    <field name="access_token" password="True"
                                           placeholder="EAAxxxx... (bearer token used for /messages)"/>
                                    <field name="app_secret" password="True"
                                           placeholder="Verifies X-Hub-Signature on inbound webhooks"/>
                                    <field name="webhook_verify_token"
                                           placeholder="Challenge response for the verification GET"/>
                                </group>
                                <div class="alert alert-info" role="alert">
                                    Webhook callback URL for this account:
                                    <code>/whatsapp/webhook</code> — the controller looks up the
                                    matching account by <em>metadata.phone_number_id</em>.
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_comm_whatsapp_account" model="ir.actions.act_window">
            <field name="name">WhatsApp Accounts</field>
            <field name="res_model">comm.whatsapp.account</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_comm_whatsapp_accounts"
                  name="WhatsApp Accounts"
                  parent="base.menu_administration"
                  action="action_comm_whatsapp_account"
                  groups="comm_whatsapp.group_whatsapp_administrator"
                  sequence="50"/>

    </data>
</odoo>
