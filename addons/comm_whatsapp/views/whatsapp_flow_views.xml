<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- WhatsApp Flow Search View -->
        <record id="view_whatsapp_flow_search" model="ir.ui.view">
            <field name="name">whatsapp.flow.search</field>
            <field name="model">whatsapp.flow</field>
            <field name="arch" type="xml">
                <search string="Search WhatsApp Flows">
                    <field name="name" string="Flow Name"/>
                    <field name="category"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'DRAFT')]"/>
                    <filter string="Published" name="published" domain="[('status', '=', 'PUBLISHED')]"/>
                    <filter string="Deprecated" name="deprecated" domain="[('status', '=', 'DEPRECATED')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- WhatsApp Flow Action -->
        <record id="action_whatsapp_flow" model="ir.actions.act_window">
            <field name="name">WhatsApp Flows</field>
            <field name="res_model">whatsapp.flow</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_whatsapp_flow_search"/>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No WhatsApp flows yet!
                </p>
                <p>
                    Create interactive flows to engage customers with forms, surveys, and multi-screen experiences.
                </p>
            </field>
        </record>

        <!-- WhatsApp Flow List View -->
        <record id="view_whatsapp_flow_tree" model="ir.ui.view">
            <field name="name">whatsapp.flow.list</field>
            <field name="model">whatsapp.flow</field>
            <field name="arch" type="xml">
                <list string="WhatsApp Flows" 
                      decoration-info="status == 'DRAFT'"
                      decoration-success="status == 'PUBLISHED'"
                      decoration-muted="status == 'DEPRECATED'">
                    <field name="name"/>
                    <field name="category"/>
                    <field name="status" widget="badge"
                           decoration-info="status == 'DRAFT'"
                           decoration-success="status == 'PUBLISHED'"
                           decoration-muted="status == 'DEPRECATED'"/>
                    <field name="flow_id_meta" optional="hide"/>
                    <field name="usage_count" optional="hide"/>
                    <field name="last_used" optional="hide" widget="datetime"/>
                </list>
            </field>
        </record>

        <!-- WhatsApp Flow Form View -->
        <record id="view_whatsapp_flow_form" model="ir.ui.view">
            <field name="name">whatsapp.flow.form</field>
            <field name="model">whatsapp.flow</field>
            <field name="arch" type="xml">
                <form string="WhatsApp Flow">
                    <header>
                        <button name="action_create_flow_meta" string="Create in Meta" type="object"
                                class="oe_highlight" icon="fa-upload"
                                invisible="flow_id_meta"/>
                        <button name="action_publish_flow" string="Publish Flow" type="object"
                                class="oe_highlight" icon="fa-check"
                                invisible="status != 'DRAFT' or not flow_id_meta"/>
                        <button name="action_fetch_from_meta" string="Sync from Meta" type="object"
                                class="btn-secondary" icon="fa-refresh"/>
                        <field name="status" widget="statusbar" statusbar_visible="DRAFT,PUBLISHED,DEPRECATED"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="flow_name_lowercase"/>
                                <field name="category"/>
                                <field name="flow_id_meta" readonly="1"/>
                                <field name="first_page_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="status" readonly="1"/>
                                <field name="version" readonly="1"/>
                                <field name="usage_count" readonly="1"/>
                                <field name="last_used" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description" name="description">
                                <field name="description" widget="text" nolabel="1"
                                       placeholder="What does this flow do? Who uses it?"/>
                            </page>

                            <page string="Screens" name="screens" invisible="use_raw_json">
                                <div class="alert alert-info" role="alert" invisible="screen_count">
                                    <i class="fa fa-magic me-1"/>
                                    <strong>Start from a template</strong> — or add screens manually below.
                                    Templates only apply to empty flows.
                                    <div class="mt-2">
                                        <button name="action_template_lead_capture" type="object"
                                                string="Lead Capture" class="btn btn-secondary me-1"
                                                icon="fa-user-plus"/>
                                        <button name="action_template_nps" type="object"
                                                string="NPS Survey" class="btn btn-secondary me-1"
                                                icon="fa-star"/>
                                        <button name="action_template_appointment" type="object"
                                                string="Appointment Booking" class="btn btn-secondary"
                                                icon="fa-calendar"/>
                                    </div>
                                </div>
                                <div class="alert alert-info" role="alert" invisible="not screen_count">
                                    <i class="fa fa-info-circle me-1"/>
                                    Drag the handle to reorder. Click a screen to add components.
                                    Mark one screen as <strong>Terminal</strong> so the user can complete the flow.
                                </div>
                                <div class="text-muted small mb-2" invisible="not screen_count">
                                    <i class="fa fa-lightbulb-o me-1"/>
                                    Click a row to edit its <strong>components</strong> (text, inputs,
                                    buttons, etc.).
                                </div>
                                <field name="screen_ids" mode="list">
                                    <list default_order="sequence asc">
                                        <field name="sequence" widget="handle"/>
                                        <field name="screen_id"/>
                                        <field name="title"/>
                                        <field name="component_count" string="Components"/>
                                        <field name="terminal" widget="boolean_toggle"/>
                                        <field name="success" widget="boolean_toggle"/>
                                    </list>
                                    <form string="Screen">
                                        <sheet>
                                            <div class="oe_title">
                                                <label for="title"/>
                                                <h1><field name="title" placeholder="Welcome"/></h1>
                                            </div>
                                            <group>
                                                <group>
                                                    <field name="screen_id" placeholder="WELCOME"/>
                                                    <field name="layout_type"/>
                                                    <field name="sequence"/>
                                                </group>
                                                <group>
                                                    <field name="terminal"/>
                                                    <field name="success"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Components" name="components">
                                                    <div class="alert alert-info" role="alert"
                                                         invisible="component_ids">
                                                        <i class="fa fa-info-circle me-1"/>
                                                        Add components below — pick a type from the dropdown,
                                                        then click the row to set its full options (text,
                                                        action target, etc.).
                                                    </div>
                                                    <field name="component_ids">
                                                        <list default_order="sequence asc">
                                                            <field name="sequence" widget="handle"/>
                                                            <field name="component_type"/>
                                                            <field name="label"/>
                                                            <field name="name"/>
                                                            <field name="required" optional="show"/>
                                                            <field name="action_type" optional="show"/>
                                                        </list>
                                                    </field>
                                                </page>
                                                <page string="Data Schema" name="data_schema">
                                                    <div class="text-muted small mb-2">
                                                        Optional JSON Schema describing dynamic data
                                                        injected from your data_exchange endpoint.
                                                    </div>
                                                    <field name="data_schema" widget="text" nolabel="1"
                                                           placeholder='{"type": "object", "properties": {...}}'/>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>

                            <page string="Validation" name="validation">
                                <field name="validation_status" widget="badge"
                                       decoration-success="validation_status == 'ok'"
                                       decoration-warning="validation_status == 'warning'"
                                       decoration-danger="validation_status == 'error'"/>
                                <field name="validation_issues" widget="text" readonly="1" nolabel="1"/>
                                <div class="text-muted small mt-2">
                                    Issues are recomputed live as you edit. Errors block sending to Meta;
                                    warnings are advisory.
                                </div>
                            </page>

                            <page string="Flow JSON" name="json">
                                <group>
                                    <field name="use_raw_json"/>
                                    <field name="flow_version"/>
                                </group>
                                <div class="text-muted small mb-2" invisible="use_raw_json">
                                    Auto-generated from the Screens tab. Tick <strong>Edit JSON directly</strong>
                                    above to override.
                                </div>
                                <field name="flow_json" widget="text" nolabel="1"
                                       readonly="not use_raw_json"/>
                                <group string="Formatted (read-only)" invisible="not flow_json_formatted or use_raw_json">
                                    <field name="flow_json_formatted" widget="text" nolabel="1" readonly="1"/>
                                </group>
                            </page>
                            
                            <page string="Preview" name="preview" invisible="not preview_url">
                                <group>
                                    <group string="Preview Information">
                                        <field name="preview_url" widget="url" readonly="1"/>
                                        <field name="preview_url_expiry_date" readonly="1"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="preview_url" widget="iframe" style="height: 850px; width: 100%;" nolabel="1"/>
                                </group>
                            </page>
                            
                            <page string="Meta Information" name="meta">
                                <group>
                                    <group string="Flow Status">
                                        <field name="flow_id_meta"/>
                                        <field name="status"/>
                                        <field name="version"/>
                                        <field name="first_page_id"/>
                                    </group>
                                    <group string="Timestamps">
                                        <field name="created_time"/>
                                        <field name="updated_time"/>
                                    </group>
                                    <group string="Preview" invisible="not preview_url">
                                        <field name="preview_url" widget="url" readonly="1"/>
                                        <field name="preview_url_expiry_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- WhatsApp Flows Menu Item -->
        <menuitem id="menu_whatsapp_flows"
                  name="Flows"
                  action="action_whatsapp_flow"
                  parent="menu_whatsapp_root"
                  sequence="30"/>
    </data>
</odoo>
